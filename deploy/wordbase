blog.norvyn.com {
    tls norvyn@norvyn.com
    encode gzip

    # API requests → Node.js
    handle /api/* {
        reverse_proxy localhost:4100
    }

    # Uploaded media → direct file serving
    handle /uploads/* {
        root * /var/www/wordbase/packages/api/data/uploads
        uri strip_prefix /uploads
        file_server
    }

    # Static site → Astro build output
    handle {
        root * /var/www/wordbase/packages/web/dist
        try_files {path} {path}.html {path}/index.html /404.html
        file_server
    }

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
