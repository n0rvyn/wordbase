# Production Caddy config: WordBase serves the apex norvyn.com
# (WordPress decommissioned 2026-05-30). blog.norvyn.com 301-redirects to apex.
# Deployed to /etc/caddy/sites.v2/wordbase by deploy/setup.sh.
norvyn.com {
    tls norvyn@norvyn.com
    encode gzip

    # API requests → Node.js
    handle /api/* {
        reverse_proxy localhost:4100
    }

    # Uploaded media → direct file serving
    handle /uploads/* {
        root * /var/www/wordbase/packages/api/data/uploads
        uri strip_prefix /uploads
        file_server
    }

    # Posts: serve the static page if it exists, otherwise fall back to Node so the
    # redirect middleware can 301 (old CJK slug → new pinyin slug, and /posts/<id>
    # canonicalization). Must precede the catch-all static handle below.
    handle /posts/* {
        root * /var/www/wordbase/packages/web/dist
        @exists file {path} {path}.html
        handle @exists {
            try_files {path} {path}.html
            file_server
        }
        handle {
            reverse_proxy localhost:4100
        }
    }

    # Static site → Astro build output
    handle {
        root * /var/www/wordbase/packages/web/dist
        try_files {path} {path}.html {path}/index.html /404.html
        file_server
    }

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# Old blog subdomain → apex (keep existing links working)
blog.norvyn.com {
    tls norvyn@norvyn.com
    redir https://norvyn.com{uri} permanent
}
