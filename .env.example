# WordBase — single environment file at the PROJECT ROOT.
#
# Loaded by packages/api/src/env.ts at startup (server / CLI / MCP / migrate),
# resolved to <repo-root>/.env regardless of cwd. On production, systemd reads
# the SAME file via `EnvironmentFile=/var/www/wordbase/.env`. Copy this to
# `.env` (git-ignored) and fill in real values. Every service var lives here —
# do NOT create a separate packages/api/.env.

# ── Core ──────────────────────────────────────────────────────────────────────
# API key for authed REST routes + the MCP server. Mint one with:
#   pnpm --filter api cli key:create <name> [permissions...]
WORDBASE_API_KEY=your_api_key_here

# SQLite path, resolved relative to the packages/api working dir (default shown).
WORDBASE_DB_PATH=./data/blog.db

# Public site origin (used for absolute links / RSS / etc.).
SITE_URL=https://norvyn.com

# Browser-facing API origin. ONLY vars prefixed `PUBLIC_` reach the client bundle
# (Astro/Vite rule) — the web admin/comments/pageview code reads this to call the
# API at <PUBLIC_SITE_URL>/api/*, which Caddy reverse-proxies to the Node server
# (same origin in prod). Leave it UNSET for local dev so the frontend falls back
# to http://localhost:4100. Set to the public origin in production.
PUBLIC_SITE_URL=https://norvyn.com

# ── App Store Connect (for app_sync / app_discover) ───────────────────────────
# asc_keys/*.p8 is git-ignored — copy it to the server separately (scp).
ASC_KEY_ID=
ASC_ISSUER_ID=
# Path to the .p8 private key. RELATIVE paths are anchored to the repo root, so
# this one value works on every machine/clone (just drop your .p8 in asc_keys/).
# Absolute paths also work if you prefer.
ASC_PRIVATE_KEY_PATH=asc_keys/AuthKey_XXXX.p8

# ── App Store Connect webhook (OPTIONAL — handler stays dormant unless set) ────
# Shared HMAC-SHA256 secret; must match the Secret entered in ASC → Webhooks.
# ASC_WEBHOOK_SECRET=

# ── WordPress migration (only for scripts/, not the runtime API) ──────────────
WP_DB_HOST=127.0.0.1
WP_DB_PORT=3307
WP_DB_USER=u_blog
WP_DB_PASSWORD=your_password_here
WP_DB_NAME=db_blog
