# WordBase API — environment variables example
# Copy to .env and fill in real values

# Database path (default: ./data/blog.db)
WORDBASE_DB_PATH=./data/blog.db

# Site URL (used for build triggers, RSS feed links, etc.)
SITE_URL=https://example.com

# App Store Connect (ASC) API credentials
# Used for syncing managed App metadata (subtitle, whatsNew, category, version).
# Prefer ASC_PRIVATE_KEY_PATH over ASC_PRIVATE_KEY to avoid shell newline escaping issues.
ASC_KEY_ID=
ASC_ISSUER_ID=
# Option A: path to your downloaded .p8 file (recommended)
ASC_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXXX.p8
# Option B: inline PEM content with literal \n for newlines (fallback)
# ASC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----

# ASC Webhook secret (for verifying App Store Connect webhook notifications)
ASC_WEBHOOK_SECRET=
