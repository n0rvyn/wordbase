---
// Shared tag-detail body for pages/tags/[slug].astro (zh) and
// pages/en/tags/[slug].astro (en). getStaticPaths stays in the shells; they
// fetch + (en) localize the posts and pass them in. Locale only prefixes the
// post links with /en.
import { estimateReadTime, stripMarkdown, type Post } from '../../lib/api';
import { formatMonoDate } from '../../lib/home';
import { enHref, type Locale } from '../../lib/locale';
import T from '../T.astro';

interface Props {
  locale: Locale;
  tagName: string;
  posts: Post[];
}

const { locale, tagName, posts } = Astro.props;
const lhref = (p: string) => (locale === 'en' ? enHref(p) : p);
---

<header class="sec wrap" style="border-top:none;padding-top:clamp(44px,6vw,80px)">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">Tag</span>
      <span class="note"><T zh={`${posts.length} 篇文章。`} en={`${posts.length} posts.`} /></span>
    </div>
    <div>
      <div class="eyebrow"><T k="tag.detail.eyebrow" /></div>
      <h1>{tagName}</h1>
    </div>
  </div>
</header>

<section class="sec wrap">
  <div class="row2">
    <div class="spine">
      <span class="no">01</span>
      <span class="lab"><T k="tag.detail.posts.lab" /></span>
    </div>
    <div>
      {posts.length === 0 ? (
        <div class="empty"><T k="tag.detail.empty" /></div>
      ) : (
        <div class="list">
          {posts.map((p: Post) => (
            <a class="item post" href={lhref(`/posts/${p.slug}`)}>
              <div>
                {p.publishedAt && <div class="pdate">{formatMonoDate(p.publishedAt)}</div>}
                <div class="item-title">{p.title}</div>
                <div class="item-sub">{p.excerpt || stripMarkdown(p.content, 120)}</div>
              </div>
              <div class="item-meta">{estimateReadTime(p.content)} min</div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }

  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 20px;
  }
  h1 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(40px, 6vw, 76px); line-height: 1.02;
    letter-spacing: -.035em; margin: 0 0 22px;
  }

  /* ── Empty state ──────────────────────────────────────────────────────────── */
  .empty { font-family: var(--font-read); color: var(--ink-3); font-size: 16px; padding: 48px 0; }

  /* ── Full-density post rows ───────────────────────────────────────────────── */
  .post { grid-template-columns: 1fr auto; gap: 6px 28px; }
  .post .item-title { font-size: clamp(19px, 2vw, 24px); margin-bottom: 6px; }
  .pdate {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--ink-3); margin-bottom: 9px;
  }
  .post .item-sub { font-size: 15px; }
  .post .item-meta { align-self: start; padding-top: 2px; }
</style>
