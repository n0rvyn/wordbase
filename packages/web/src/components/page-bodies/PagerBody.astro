---
// Shared paginated-list body for pages/page/[page].astro (zh) and
// pages/en/page/[page].astro (en). getStaticPaths + paginate() stay in the
// shells (Astro requires them in the route file); the shells pass the page's
// fields + the (en-localized) posts. page.url.prev/next are already route-
// correct (/page/N for zh, /en/page/N for en), so they pass straight through;
// locale only changes the post-link prefix and the "back home" target.
import { estimateReadTime, stripMarkdown, type Post } from '../../lib/api';
import { formatMonoDate } from '../../lib/home';
import { enHref, type Locale } from '../../lib/locale';
import T from '../T.astro';

interface Props {
  locale: Locale;
  currentPage: number;
  lastPage: number;
  posts: Post[];
  urlPrev?: string;
  urlNext?: string;
}

const { locale, currentPage, lastPage, posts, urlPrev, urlNext } = Astro.props;
const en = locale === 'en';
const lhref = (p: string) => (en ? enHref(p) : p);
const homeHref = en ? '/en' : '/';
---

<header class="sec wrap" style="border-top:none;padding-top:clamp(44px,6vw,80px)">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">Page {currentPage}</span>
      <span class="note"><T zh={`${currentPage} / ${lastPage}`} en={`${currentPage} / ${lastPage}`} /></span>
    </div>
    <div>
      <div class="eyebrow"><T zh={`Writing · 第 ${currentPage} 页`} en={`Writing · Page ${currentPage}`} /></div>
      <h1><T k="pager.h1" /></h1>
    </div>
  </div>
</header>

<section class="sec wrap">
  <div class="row2">
    <div class="spine">
      <span class="no">01</span>
      <span class="lab"><T k="pager.posts.lab" /></span>
    </div>
    <div>
      <div class="list">
        {posts.map((p: Post) => (
          <a class="item post" href={lhref(`/posts/${p.slug}`)}>
            <div>
              {p.publishedAt && <div class="pdate">{formatMonoDate(p.publishedAt)}</div>}
              <div class="item-title">{p.title}</div>
              <div class="item-sub">{p.excerpt || stripMarkdown(p.content, 120)}</div>
            </div>
            <div class="item-meta">{estimateReadTime(p.content)} min</div>
          </a>
        ))}
      </div>

      <nav class="pager">
        {urlPrev ? (
          <a class="pager-btn" href={currentPage === 2 ? homeHref : urlPrev}><T k="pager.newer" /></a>
        ) : (
          <a class="pager-btn" href={homeHref}><T k="pager.home" /></a>
        )}
        <span class="pager-cur">{currentPage} / {lastPage}</span>
        {urlNext ? (
          <a class="pager-btn" href={urlNext}><T k="pager.older" /></a>
        ) : (
          <span class="pager-btn pager-ghost"><T k="pager.older" /></span>
        )}
      </nav>
    </div>
  </div>
</section>

<style>
  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }

  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 20px;
  }
  h1 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(40px, 6vw, 76px); line-height: 1.02;
    letter-spacing: -.035em; margin: 0 0 22px;
  }

  /* ── Full-density post rows ───────────────────────────────────────────────── */
  .post { grid-template-columns: 1fr auto; gap: 6px 28px; }
  .post .item-title { font-size: clamp(19px, 2vw, 24px); margin-bottom: 6px; }
  .pdate {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--ink-3); margin-bottom: 9px;
  }
  .post .item-sub { font-size: 15px; }
  .post .item-meta { align-self: start; padding-top: 2px; }

  /* ── Pager ────────────────────────────────────────────────────────────────── */
  .pager {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--line);
  }
  .pager-btn {
    font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .08em;
    text-transform: uppercase; color: var(--ink-3);
    padding: 8px 16px; border: 1px solid var(--line); border-radius: 99px;
    transition: color .2s, border-color .2s;
  }
  .pager-btn:hover { color: var(--ink); border-color: var(--line-2); }
  .pager-ghost { opacity: 0; pointer-events: none; }
  .pager-cur {
    font-family: var(--font-mono); font-size: 11.5px;
    color: var(--ink-3); letter-spacing: .05em;
  }

  /* ── Responsive ───────────────────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .post { grid-template-columns: 1fr; }
    .post .item-meta { margin-top: 8px; }
  }
</style>
