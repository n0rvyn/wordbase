---
// Shared 404 body for pages/404.astro (zh) and pages/en/404.astro (en).
// Locale only changes the "back home" link target (/ vs /en).
import { enHref, type Locale } from '../../lib/locale';
import T from '../T.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const homeHref = locale === 'en' ? enHref('/') : '/';
---

<div class="not-found">
  <span class="not-found-code">404</span>
  <h1 class="not-found-title"><T k="nf.title" /></h1>
  <p class="not-found-text"><T k="nf.text" /></p>
  <a href={homeHref} class="not-found-link"><T k="nf.back" /></a>
</div>

<style>
  .not-found {
    text-align: center;
    padding: 6rem 0;
  }

  .not-found-code {
    display: block;
    font-family: var(--font-display);
    font-size: 8rem;
    font-weight: 700;
    line-height: 1;
    color: var(--line);
    margin-bottom: 1rem;
  }

  .not-found-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--ink);
  }

  .not-found-text {
    font-family: var(--font-read);
    color: var(--ink-3);
    margin-bottom: 2rem;
  }

  .not-found-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
  }

  .not-found-link:hover {
    text-decoration: underline;
  }
</style>
