---
// Shared home-page body. Single source of markup + scoped styles for both the
// zh shell (pages/index.astro) and the en shell (pages/en/index.astro). The
// shells fetch+localize via lib/home.loadHomeData and spread the result here;
// this component is pure presentation. Locale only affects internal link hrefs
// (en prefixes /en) and which on-page anchor a hero CTA targets — content
// shape (category meta, podcast section) is decided by the data the shell
// passes (postCat/podcast null on en), not by branching here.
import T from '../T.astro';
import {
  stripMarkdown,
  estimateReadTime,
  type Post,
  type App,
  type Episode,
  type Podcast,
} from '../../lib/api';
import {
  formatMonoDate,
  decodeEntities,
  selectFeaturedApp,
  restApps,
  selectFeaturedEpisode,
  formatDuration,
} from '../../lib/home';
import { enHref, type Locale } from '../../lib/locale';

interface Props {
  locale: Locale;
  posts: Post[];
  postCat: Map<string, string> | null;
  apps: App[];
  podcast: Podcast | null;
  episodes: Episode[];
}

const { locale, posts, postCat, apps, podcast, episodes } = Astro.props;
const en = locale === 'en';
// Localize an internal path for the active locale. /podcast has no en twin, so
// callers pass it raw (never through lhref).
const lhref = (p: string) => (en ? enHref(p) : p);

const featuredApp = selectFeaturedApp(apps);
const listApps = restApps(apps, featuredApp);
const showApps = apps.length > 0;

const featuredEp = podcast ? selectFeaturedEpisode(episodes) : null;
const listEps = featuredEp ? episodes.filter((e) => e.id !== featuredEp.id).slice(0, 5) : [];
const showPodcast = !!(podcast && featuredEp);

// Hero CTAs scroll to the on-page section when it is rendered, else link to the
// standalone page. zh renders both → #apps / #podcast; en omits podcast → the
// podcast CTA links out to /podcast (the Chinese show page).
const appsCtaHref = showApps ? '#apps' : lhref('/apps');
const podcastCtaHref = showPodcast ? '#podcast' : '/podcast';
---

{/* HERO */}
<header class="hero wrap">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">norvyn</span>
      <span class="note"><T k="home.spine.note" /></span>
    </div>
    <div class="hero-main">
      <div class="eyebrow"><T k="home.hero.eyebrow" /></div>
      <h1><T k="home.hero.h1" /></h1>
      <p class="lede"><T k="home.hero.lede" /></p>
      <div class="hero-cta">
        <a class="btn btn-1" href={appsCtaHref}><T k="home.hero.ctaApps" /><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        <a class="btn btn-2" href={podcastCtaHref}><T k="home.hero.ctaPodcast" /></a>
      </div>
    </div>
  </div>
</header>

{/* APPS */}
{showApps && (
  <section class="sec wrap" id="apps">
    <div class="row2">
      <div class="spine">
        <span class="no">01</span>
        <span class="lab">Apps</span>
        <span class="note"><T k="home.apps.note" /></span>
      </div>
      <div class="apps">
        {featuredApp && (
          <a class="feature" href={lhref(`/apps/${featuredApp.slug}`)}>
            <div class="phone">
              <div class="screen">
                <div class="s-top"><span>9:41</span><span>{featuredApp.name}</span></div>
                {featuredApp.icon
                  ? <img src={featuredApp.icon} alt={featuredApp.name} width="96" height="96" style="border-radius:22px;" />
                  : <div class="app-ic" style="width:96px;height:96px;font-size:36px;">{featuredApp.name.charAt(0)}</div>
                }
                <div class="s-lab">{featuredApp.tagline}</div>
              </div>
            </div>
            <div class="feature-body">
              <div class="ftag"><T k="home.apps.featuredTag" /></div>
              <h3>{featuredApp.name}</h3>
              {featuredApp.tagline && <p>{featuredApp.tagline}</p>}
              <div class="fmeta">
                {featuredApp.category && (
                  <div>
                    <span class="k"><T k="home.meta.category" /></span>
                    <span class="v">{featuredApp.category}</span>
                  </div>
                )}
                {featuredApp.publishedAt && (
                  <div>
                    <span class="k"><T k="home.meta.since" /></span>
                    <span class="v">{new Date(featuredApp.publishedAt * 1000).getUTCFullYear()}</span>
                  </div>
                )}
                {featuredApp.appStoreUrl && (
                  <div>
                    <span class="k"><T k="home.meta.store" /></span>
                    <span class="v"><T k="home.meta.appStore" /> ↗</span>
                  </div>
                )}
              </div>
            </div>
          </a>
        )}
        <div class="list">
          {listApps.map((a: App) => (
            <a class="item app" href={lhref(`/apps/${a.slug}`)}>
              <div class="app-ic">
                {a.icon
                  ? <img src={a.icon} alt={a.name} width="50" height="50" style="border-radius:13px;width:100%;height:100%;object-fit:cover;" />
                  : a.name.charAt(0)
                }
              </div>
              <div>
                <div class="item-title">{a.name}</div>
                {a.tagline && <div class="item-sub">{a.tagline}</div>}
              </div>
              <div class="app-r">
                {(a.category || a.publishedAt) && (
                  <span class="item-meta">
                    {[a.category, a.publishedAt ? String(new Date(a.publishedAt * 1000).getUTCFullYear()) : null].filter(Boolean).join(' · ')}
                  </span>
                )}
                {a.appStoreUrl && (
                  <span class="store"><T k="home.meta.appStore" /> <svg class="arrow" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span>
                )}
              </div>
            </a>
          ))}
        </div>
        <a class="viewall" href={lhref('/apps')}><T k="home.apps.viewall" /> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
    </div>
  </section>
)}

{/* WRITING (always rendered — 126 real posts) */}
<section class="sec wrap" id="writing">
  <div class="row2">
    <div class="spine">
      <span class="no">02</span>
      <span class="lab">Writing</span>
      <span class="note"><T k="home.writing.note" /></span>
    </div>
    <div>
      <div class="list">
        {posts.map((p: Post) => {
          const cat = postCat?.get(p.id);
          return (
            <a class="item post" href={lhref(`/posts/${p.slug}`)}>
              <div>
                {p.publishedAt && <div class="pdate">{formatMonoDate(p.publishedAt)}</div>}
                <div class="item-title">{p.title}</div>
                <div class="item-sub">{p.excerpt || stripMarkdown(p.content, 120)}</div>
              </div>
              <div class="item-meta">
                {`${estimateReadTime(p.content)} min${cat ? ' · ' + cat : ''}`}
              </div>
            </a>
          );
        })}
      </div>
      <a class="viewall" href={lhref('/writing')}><T k="home.writing.viewall" /> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
    </div>
  </div>
</section>

{/* PODCAST */}
{showPodcast && podcast && featuredEp && (
  <section class="sec wrap" id="podcast">
    <div class="row2">
      <div class="spine">
        <span class="no">03</span>
        <span class="lab">{decodeEntities(podcast.title)}</span>
        {podcast.description && stripMarkdown(podcast.description, 40) && (
          <span class="note">{stripMarkdown(podcast.description, 40)}</span>
        )}
      </div>
      <div class="pods">
        <div class="feat-ep">
          <div class="ep-cover">
            {(podcast.coverImage || featuredEp.coverImage)
              ? <img src={podcast.coverImage || featuredEp.coverImage || ''} alt={podcast.title} width="104" height="104" style="border-radius:18px;width:100%;height:100%;object-fit:cover;" />
              : <span>{decodeEntities(podcast.title).charAt(0)}</span>
            }
          </div>
          <div class="eb">
            <span class="en">
              {featuredEp.episodeNumber != null ? `EP.${featuredEp.episodeNumber} · ` : ''}<T k="home.podcast.featuredPrefix" />
            </span>
            <h3>{featuredEp.title}</h3>
            <audio controls preload="metadata" src={featuredEp.audioUrl}></audio>
          </div>
        </div>
        <div class="list">
          {listEps.map((e: Episode) => {
            const metaParts = [
              e.episodeNumber != null ? `EP.${e.episodeNumber}` : null,
              formatDuration(e.duration) || null,
            ].filter(Boolean).join(' · ');
            return (
              <a class="item ep" href="/podcast">
                <div class="mini" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.5v13l11-6.5z"/></svg>
                </div>
                <div class="item-title">{e.title}</div>
                {metaParts && <div class="item-meta">{metaParts}</div>}
              </a>
            );
          })}
        </div>
        <a class="viewall" href="/podcast"><T k="home.podcast.viewall" /> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
    </div>
  </section>
)}

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .hero { padding: clamp(52px, 8vw, 104px) 0 clamp(40px, 5vw, 64px); }
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 22px;
  }
  .hero h1 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(33px, 4.6vw, 60px); line-height: 1.08;
    letter-spacing: -.03em; margin: 0 0 clamp(38px, 4vw, 46px); max-width: 18ch;
    text-wrap: balance;
  }
  .hero h1 em { font-style: normal; color: var(--accent); }
  .lede {
    font-family: var(--font-read); font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.75; color: var(--ink-2); max-width: 50ch; margin: 0 0 clamp(42px, 4.5vw, 52px);
  }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 12px; }

  /* ── Buttons ──────────────────────────────────────────────────────────────── */
  .btn {
    font-family: var(--font-ui); font-size: 15px; font-weight: 600;
    cursor: pointer; padding: 12px 20px; border-radius: 99px;
    border: 1px solid transparent;
    transition: transform .18s var(--ease), background .2s, border-color .2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn-1 { background: var(--accent); color: var(--on-accent); }
  .btn-2 { background: transparent; color: var(--ink); border-color: var(--line-2); }
  .btn-2:hover { border-color: var(--ink-3); background: var(--surface-2); }

  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }

  /* ── Arrow ────────────────────────────────────────────────────────────────── */
  .arrow { color: var(--ink-3); transition: transform .25s var(--ease), color .2s; }
  .item:hover .arrow { transform: translate(3px, -3px); color: var(--accent); }

  /* ── App list rows ────────────────────────────────────────────────────────── */
  .app { grid-template-columns: 50px 1fr auto; gap: 20px; }
  .app-ic {
    width: 50px; height: 50px; border-radius: 13px;
    background: var(--surface-2); border: 1px solid var(--line);
    display: grid; place-items: center;
    font-family: var(--font-display); font-weight: 600;
    font-size: 19px; color: var(--ink-3);
    transition: color .2s, border-color .2s;
  }
  .item:hover .app-ic { color: var(--accent); border-color: var(--line-2); }
  .app .item-title { font-size: 19px; }
  .app .item-sub { font-size: 14.5px; margin-top: 3px; }
  .app-r { display: flex; flex-direction: column; align-items: flex-end; gap: 7px; text-align: right; }
  .app-r .store {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .06em;
    color: var(--ink-3); display: inline-flex; gap: 5px; align-items: center;
    transition: color .2s; white-space: nowrap;
  }
  .item:hover .store { color: var(--accent); }

  /* ── Featured app ─────────────────────────────────────────────────────────── */
  .feature {
    display: grid; grid-template-columns: 248px 1fr;
    gap: clamp(28px, 4vw, 56px); align-items: center;
    padding-bottom: 30px; margin-bottom: 14px;
    border-bottom: 1px solid var(--line);
  }
  .phone {
    width: 230px; aspect-ratio: 9/19.2; border-radius: 38px;
    background: var(--surface); border: 1px solid var(--line-2);
    padding: 9px; box-shadow: var(--shadow);
    position: relative; margin-inline: auto;
  }
  .phone::before {
    content: ""; position: absolute; top: 15px; left: 50%;
    transform: translateX(-50%); width: 54px; height: 6px;
    border-radius: 99px; background: var(--surface-3); z-index: 2;
  }
  .screen {
    width: 100%; height: 100%; border-radius: 30px; overflow: hidden;
    position: relative;
    background: radial-gradient(130% 90% at 50% 0%, color-mix(in srgb, var(--accent) 22%, var(--surface-2)), var(--surface-2));
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 18px; color: var(--ink);
  }
  .s-top {
    position: absolute; top: 14px; left: 0; right: 0;
    display: flex; justify-content: space-between; padding: 0 22px;
    font-family: var(--font-mono); font-size: 10px; color: var(--ink-3);
  }
  .s-lab { font-family: var(--font-read); font-size: 13px; color: var(--ink-2); }
  .feature-body .ftag {
    font-family: var(--font-mono); font-size: 11.5px;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 14px;
  }
  .feature-body h3 {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(26px, 3.2vw, 38px); letter-spacing: -.03em;
    margin: 0 0 14px; line-height: 1.08;
  }
  .feature-body p {
    color: var(--ink-2); font-family: var(--font-read);
    font-size: 16px; line-height: 1.7; margin: 0 0 22px; max-width: 42ch;
  }
  .feature-body .fmeta { display: flex; gap: 22px; flex-wrap: wrap; }
  .feature-body .fmeta div { display: flex; flex-direction: column; gap: 3px; }
  .feature-body .fmeta .k {
    font-family: var(--font-mono); font-size: 10.5px;
    letter-spacing: .1em; text-transform: uppercase; color: var(--ink-3);
  }
  .feature-body .fmeta .v { font-weight: 600; font-size: 15px; }

  /* ── Writing rows ─────────────────────────────────────────────────────────── */
  .post { grid-template-columns: 1fr auto; gap: 6px 28px; }
  .post .item-title { font-size: clamp(19px, 2vw, 24px); margin-bottom: 6px; }
  .pdate { font-family: var(--font-mono); font-size: 12px; color: var(--ink-3); margin-bottom: 9px; }
  .post .item-sub { font-size: 15px; }
  .post .item-meta { align-self: start; padding-top: 2px; }

  /* ── Featured episode ─────────────────────────────────────────────────────── */
  .feat-ep {
    display: grid; grid-template-columns: auto 1fr;
    gap: 22px; align-items: center;
    padding: 8px 0 28px; margin-bottom: 8px;
    border-bottom: 1px solid var(--line);
  }
  .ep-cover {
    width: 104px; height: 104px; border-radius: 18px; flex-shrink: 0;
    background: radial-gradient(120% 120% at 20% 0%, color-mix(in srgb, var(--accent) 50%, #15151a), #0e0e14);
    display: grid; place-items: center; box-shadow: var(--shadow);
  }
  .ep-cover span {
    font-family: var(--font-display); font-weight: 700;
    font-size: 30px; color: #fff; letter-spacing: -.03em;
  }
  .feat-ep .eb .en {
    font-family: var(--font-mono); font-size: 11.5px;
    letter-spacing: .1em; text-transform: uppercase; color: var(--accent);
  }
  .feat-ep .eb h3 {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(20px, 2.3vw, 26px); letter-spacing: -.02em; margin: 8px 0 16px;
  }
  audio { width: 100%; max-width: 420px; margin-top: 8px; }

  /* ── Episode list rows ────────────────────────────────────────────────────── */
  .ep { grid-template-columns: auto 1fr auto; gap: 16px; }
  .ep .mini {
    width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
    border: 1px solid var(--line-2); background: transparent;
    color: var(--ink-3); display: grid; place-items: center;
    transition: all .2s;
  }
  .item:hover .mini { border-color: var(--accent); color: var(--accent); }
  .ep .mini svg { width: 12px; height: 12px; }
  .ep .item-title { font-size: 16px; }

  /* ── View all link ────────────────────────────────────────────────────────── */
  .viewall {
    display: inline-flex; align-items: center; gap: 7px; margin-top: 24px;
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--accent); font-weight: 500;
    transition: gap .2s var(--ease);
  }
  .viewall:hover { gap: 11px; }

  /* ── Section-local responsive ─────────────────────────────────────────────── */
  @media (max-width: 880px) {
    .feature { grid-template-columns: 1fr; gap: 30px; }
    .feat-ep { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .app { grid-template-columns: 44px 1fr; }
    .app-r { grid-column: 2; align-items: flex-start; text-align: left; flex-direction: row; gap: 14px; margin-top: 8px; }
    .post { grid-template-columns: 1fr; }
    .post .item-meta { margin-top: 8px; }
  }
</style>
