---
// Shared archives-page body. Single source of markup + scoped styles for the
// zh shell (pages/archives.astro) and the en shell (pages/en/archives.astro).
// Shells load + localize via lib/writing.loadArchivesData and pass the grouped
// posts here; this component is pure presentation. Locale only prefixes the
// post links with /en.
import { estimateReadTime, type Post } from '../../lib/api';
import { formatMonoDate } from '../../lib/home';
import type { YearGroup } from '../../lib/writing';
import { enHref, type Locale } from '../../lib/locale';
import T from '../T.astro';

interface Props {
  locale: Locale;
  groups: YearGroup[];
  totalPosts: number;
}

const { locale, groups, totalPosts } = Astro.props;
const lhref = (p: string) => (locale === 'en' ? enHref(p) : p);
---

<header class="sec wrap" style="border-top:none;padding-top:clamp(44px,6vw,80px)">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">Archive</span>
      <span class="note"><T zh={`${totalPosts} 篇文章，按时间倒序。`} en={`${totalPosts} posts, newest first.`} /></span>
    </div>
    <div>
      <div class="eyebrow"><T k="archives.eyebrow" /></div>
      <h1><T k="archives.h1" /></h1>
      <p class="lede-w"><T k="archives.lede" /></p>
    </div>
  </div>
</header>

<section class="sec wrap">
  <div class="row2">
    <div class="spine">
      <span class="no">01</span>
      <span class="lab"><T k="archives.all.lab" /></span>
    </div>
    <div id="postList">
      {groups.map(group => (
        <div class="year-section">
          <div class="year-head">
            <span class="mono">{group.year === 0 ? <T k="writing.yearUnknown" /> : group.year}</span>
          </div>
          <div class="list">
            {group.posts.map((p: Post) => (
              <a class="item post compact" href={lhref(`/posts/${p.slug}`)}>
                <div class="compact-inner">
                  {p.publishedAt && <span class="pdate compact-date">{formatMonoDate(p.publishedAt)}</span>}
                  <span class="item-title compact-title">{p.title}</span>
                  <span class="item-meta compact-cat">{estimateReadTime(p.content)} min</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }

  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 20px;
  }
  h1 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(40px, 6vw, 76px); line-height: 1.02;
    letter-spacing: -.035em; margin: 0 0 22px;
  }
  .lede-w {
    font-family: var(--font-read); font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.75; color: var(--ink-2); max-width: 46ch; margin: 0;
  }

  /* ── Year heading ─────────────────────────────────────────────────────────── */
  .year-head {
    padding: 28px 4px 8px;
    border-top: 1px solid var(--line);
  }
  .year-head .mono {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .13em; text-transform: uppercase;
    color: var(--ink-3);
  }
  .year-section:first-child .year-head { border-top: none; }

  /* ── Compact post rows ────────────────────────────────────────────────────── */
  .post.compact { grid-template-columns: 1fr; }
  .compact-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0 16px;
    align-items: baseline;
  }
  .compact-date {
    font-family: var(--font-mono); font-size: 11.5px;
    color: var(--ink-3); white-space: nowrap;
  }
  .compact-title {
    font-family: var(--font-display); font-weight: 600;
    font-size: 16px; letter-spacing: -.018em; transition: color .2s;
  }
  .item:hover .compact-title { color: var(--accent); }
  .compact-cat {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-3); white-space: nowrap; text-align: right;
  }

  /* ── Responsive ───────────────────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .compact-inner { grid-template-columns: 1fr auto; }
    .compact-date { display: none; }
  }
</style>
