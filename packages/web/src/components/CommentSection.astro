---
import T from './T.astro';

interface Props {
  postId: string;
}

const { postId } = Astro.props;
const apiUrl = (import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4100').replace(/\/$/, '');
---

<section id="comments" class="cs" data-post-id={postId} data-api-url={apiUrl}>
  <h2 class="cs-title"><T k="comment.title" /></h2>

  <div id="comments-list" class="cs-list">
    <p class="cs-status"><T k="comment.loading" /></p>
  </div>

  <div class="cs-form-wrap">
    <h3 class="cs-form-title"><T k="comment.formTitle" /></h3>
    <form id="comment-form" class="cs-form">
      <div class="cs-row2">
        <div class="cs-field">
          <label for="author_name" class="cs-label"><T k="comment.name" /></label>
          <input type="text" id="author_name" name="author_name" required class="cs-input" />
        </div>
        <div class="cs-field">
          <label for="author_email" class="cs-label"><T k="comment.email" /></label>
          <input type="email" id="author_email" name="author_email" class="cs-input" />
        </div>
      </div>
      <div class="cs-field">
        <label for="author_url" class="cs-label"><T k="comment.url" /></label>
        <input type="url" id="author_url" name="author_url" placeholder="https://" class="cs-input" />
      </div>
      <div class="cs-field">
        <label for="content" class="cs-label"><T k="comment.content" /></label>
        <textarea id="content" name="content" rows="4" required class="cs-input cs-textarea"></textarea>
      </div>
      <button type="submit" class="cs-submit"><T k="comment.submit" /></button>
      <p id="form-message" class="cs-msg msg-hidden"></p>
    </form>
  </div>
</section>

<style>
  .cs {
    border-top: 1px solid var(--line);
    padding-top: 40px;
    margin-top: 40px;
  }

  .cs-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 28px;
  }

  .cs-list {
    margin-bottom: 40px;
  }

  .cs-status {
    font-family: var(--font-read);
    font-size: 14.5px;
    color: var(--ink-3);
    margin: 0;
  }

  .cs-form-wrap {
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 28px;
  }

  .cs-form-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 20px;
  }

  .cs-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cs-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .cs-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cs-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .cs-input {
    font-family: var(--font-ui);
    font-size: 14.5px;
    color: var(--ink);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 10px 14px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  .cs-input:focus {
    border-color: var(--accent);
  }

  .cs-textarea {
    resize: vertical;
    min-height: 96px;
  }

  .cs-submit {
    align-self: flex-start;
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 600;
    color: var(--on-accent);
    background: var(--accent);
    border: none;
    border-radius: 99px;
    padding: 10px 24px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .cs-submit:hover {
    opacity: 0.88;
  }

  .cs-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cs-msg {
    font-family: var(--font-read);
    font-size: 13.5px;
    margin: 0;
  }

  .msg-hidden {
    display: none;
  }

  @media (max-width: 560px) {
    .cs-row2 {
      grid-template-columns: 1fr;
    }

    .cs-form-wrap {
      padding: 20px;
    }
  }
</style>

<script>
  import { escapeHtml } from '../lib/escape';
  import { t, type Lang } from '../lib/i18n';

  const section = document.getElementById('comments')!;
  const postId = section.dataset.postId!;
  const apiUrl = section.dataset.apiUrl!;
  const listEl = document.getElementById('comments-list')!;

  // Read the active language from <html data-lang> (set by BaseLayout's head
  // bootstrap before paint; matches the language the user is currently
  // viewing, not the persisted preference). Defaults to 'zh' if missing.
  const uiLang: Lang = (document.documentElement.dataset.lang as Lang) || 'zh';
  const tr = (key: string) => t(key)[uiLang];

  function formatDate(ts: number): string {
    return new Date(ts * 1000).toLocaleDateString('zh-CN', {
      year: 'numeric', month: 'long', day: 'numeric',
    });
  }

  function renderComment(c: any, depth = 0): string {
    const ml = depth > 0 ? `margin-left:${depth * 1.5}rem;` : '';
    return `
      <div style="${ml}border-top:1px solid var(--line);padding:16px 0;">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <span style="font-family:var(--font-display);font-weight:600;font-size:14.5px;color:var(--ink);">${escapeHtml(c.authorName)}</span>
          <span style="font-family:var(--font-mono);font-size:11.5px;color:var(--ink-3);">${formatDate(c.createdAt)}</span>
        </div>
        <p style="font-family:var(--font-read);font-size:15px;color:var(--ink-2);margin:0;">${escapeHtml(c.content)}</p>
      </div>
    `;
  }

  async function loadComments() {
    try {
      const res = await fetch(`${apiUrl}/api/posts/${postId}/comments?status=approved`);
      const { data } = await res.json();

      if (data.length === 0) {
        listEl.innerHTML = `<p style="font-family:var(--font-read);font-size:14.5px;color:var(--ink-3);margin:0;">${tr('comment.empty')}</p>`;
        return;
      }

      // Build tree: separate root and replies
      const roots = data.filter((c: any) => !c.parentId);
      const replies = data.filter((c: any) => c.parentId);
      const replyMap = new Map<string, any[]>();
      replies.forEach((r: any) => {
        if (!replyMap.has(r.parentId)) replyMap.set(r.parentId, []);
        replyMap.get(r.parentId)!.push(r);
      });

      let html = '';
      roots.forEach((c: any) => {
        html += renderComment(c, 0);
        const childReplies = replyMap.get(c.id) || [];
        childReplies.forEach((r: any) => {
          html += renderComment(r, 1);
        });
      });

      listEl.innerHTML = html;
    } catch {
      listEl.innerHTML = `<p style="font-family:var(--font-read);font-size:14.5px;color:var(--ink-3);margin:0;">${tr('comment.loadError')}</p>`;
    }
  }

  loadComments();

  // Handle form submission
  const form = document.getElementById('comment-form') as HTMLFormElement;
  const msgEl = document.getElementById('form-message')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;

    const formData = new FormData(form);
    const body = {
      author_name: formData.get('author_name'),
      author_email: formData.get('author_email') || undefined,
      author_url: formData.get('author_url') || undefined,
      content: formData.get('content'),
    };

    try {
      const res = await fetch(`${apiUrl}/api/posts/${postId}/comments`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        msgEl.textContent = tr('comment.posted');
        msgEl.style.color = 'var(--ink-2)';
        msgEl.classList.remove('msg-hidden');
        form.reset();
      } else {
        const err = await res.json();
        msgEl.textContent = err.error?.message || tr('comment.submitError');
        msgEl.style.color = 'var(--ink-3)';
        msgEl.classList.remove('msg-hidden');
      }
    } catch {
      msgEl.textContent = tr('comment.netError');
      msgEl.style.color = 'var(--ink-3)';
      msgEl.classList.remove('msg-hidden');
    } finally {
      btn.disabled = false;
    }
  });
</script>
