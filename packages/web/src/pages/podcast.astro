---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getPodcasts,
  getEpisodes,
  stripMarkdown,
  type Episode,
} from '../lib/api';
import { selectFeaturedEpisode, decodeEntities } from '../lib/home';
import { selectShow, sortEpisodes, episodeMeta } from '../lib/podcast';
import { FEEDBACK_CHIPS } from '../lib/feedback';
import { buildPodcastLd } from '../lib/jsonld.js';

const apiUrl = (import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4100').replace(/\/$/, '');

const { data: podcasts } = await getPodcasts({ status: 'published' });
const podcast = selectShow(podcasts);

let episodes: Episode[] = [];
if (podcast) {
  episodes = (await getEpisodes(podcast.slug, { status: 'published', limit: 10000 })).data;
}

const featuredEp = selectFeaturedEpisode(episodes);
const archive = sortEpisodes(episodes).filter(e => e.id !== featuredEp?.id);

const showTitle = podcast ? decodeEntities(podcast.title) : '播客';
const feedHref = podcast ? `/api/podcasts/${podcast.slug}/feed.xml` : null;
const host = podcast?.author ?? podcast?.ownerName ?? null;
const showCover = podcast?.coverImage || featuredEp?.coverImage || null;

// Grey 2-line blurb for an episode row — short summary only (full transcript
// lives in showNotes / content:encoded, far too long for the list). Returns
// '' when absent so the markup can skip rendering an empty line.
const epBlurb = (ep: Episode): string => (ep.summary ? stripMarkdown(ep.summary, 180) : '');

const origin = Astro.site!.href.replace(/\/$/, '');
const jsonLd = podcast ? [buildPodcastLd(podcast, episodes, origin)] : [];
---

<BaseLayout
  title={podcast ? showTitle : '播客'}
  description={podcast?.description ? stripMarkdown(podcast.description, 120) : '一档慢节奏的播客。'}
  ogImage="/og-podcast.png"
  jsonLd={jsonLd}
  feeds={feedHref ? [{ title: `${showTitle} · Podcast`, href: feedHref }] : []}
>

<!-- 00 HERO — show header (cover + identity) -->
<header class="sec wrap" style="border-top:none;padding-top:clamp(44px,6vw,80px)">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">Podcast</span>
      {podcast && <span class="note">自制的 AI 信息源</span>}
      {!podcast && <span class="note">一档慢节奏的播客。</span>}
    </div>
    <div class="show-head">
      <div class="eyebrow">
        Podcast{host ? ` · 主播 ${host}` : ''}
      </div>
      <div class="show-body">
        <div class="show-id">
          <div class="show-cover">
            {showCover
              ? <img src={showCover} alt={showTitle} width="132" height="132" loading="eager" />
              : <span>{showTitle.charAt(0)}</span>
            }
          </div>
          {feedHref && (
            <div class="subscribe">
              <a class="btn btn-1" href={feedHref}>订阅 · RSS ↗</a>
              {podcast?.link && (
                <a class="btn btn-2" href={podcast.link} target="_blank" rel="noopener noreferrer">在播客客户端收听</a>
              )}
            </div>
          )}
        </div>
        <div class="show-meta">
          <h1 class="show-title">{showTitle}</h1>
          <p class="lede">
            {podcast?.description ? stripMarkdown(podcast.description, podcast.description.length) : '一档慢节奏的播客。'}
          </p>
        </div>
      </div>
    </div>
  </div>
</header>

{!podcast && (
  <!-- Empty path A: no published podcast -->
  <section class="sec wrap">
    <div class="empty">播客即将上线，敬请期待。</div>
  </section>
)}

{podcast && !featuredEp && (
  <!-- Empty path B: podcast exists but no episodes -->
  <section class="sec wrap">
    <div class="row2">
      <div class="spine">
        <span class="no">01</span>
        <span class="lab">Latest</span>
        <span class="note">最新一期。</span>
      </div>
      <div class="empty">暂无单集。</div>
    </div>
  </section>
)}

{podcast && featuredEp && (
  <!-- 01 LATEST — same row structure as the archive, just emphasized -->
  <section class="sec wrap">
    <div class="row2">
      <div class="spine">
        <span class="no">01</span>
        <span class="lab">Latest</span>
        <span class="note">最新一期。</span>
      </div>
      <div class="ep-list">
        <article class="ep-item ep-item--feature" id={`ep-${featuredEp.slug}`}>
          <span class="ep-eyebrow ep-eyebrow--accent">
            {featuredEp.episodeNumber != null ? `EP.${featuredEp.episodeNumber} · 最新一期` : '最新一期'}
          </span>
          <div class="ep-title-row">
            <h3 class="ep-title">{featuredEp.title}</h3>
            <button type="button" class="ep-share" data-ep-slug={featuredEp.slug} title="分享本集" aria-label="分享本集">
              <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 16V4"/><path d="m8 8 4-4 4 4"/><path d="M5 12v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6"/>
              </svg>
            </button>
          </div>
          {epBlurb(featuredEp) && <p class="ep-sum">{epBlurb(featuredEp)}</p>}
          <audio controls preload="none" src={`/api/podcasts/episodes/${encodeURIComponent(featuredEp.slug)}/download`}></audio>
          {featuredEp.transcript && (
            <div class="tx" data-slug={featuredEp.slug} data-api-url={apiUrl}>
              <button type="button" class="tx-toggle" aria-expanded="false">逐字稿<span class="tx-caret">▾</span></button>
              <div class="tx-panel" hidden>
                <div class="tx-body"></div>
              </div>
            </div>
          )}
          <div class="ep-fb" data-slug={featuredEp.slug} data-api-url={apiUrl}>
            <div class="ep-fb-chips">
              {FEEDBACK_CHIPS.map((chip) => (
                <button type="button" class="ep-fb-chip" data-category={chip.category}>{chip.label}</button>
              ))}
              <button type="button" class="ep-fb-say">说一句</button>
            </div>
            <input class="ep-fb-note msg-hidden" type="text" maxlength="200" placeholder="一句话（可选）" />
            <p class="ep-fb-hint msg-hidden">写完，点上面任一个表情发出去</p>
            <p class="ep-fb-msg msg-hidden"></p>
            <p class="ep-fb-thanks msg-hidden">已收到 · 谢谢</p>
          </div>
        </article>
      </div>
    </div>
  </section>
)}

{podcast && archive.length > 0 && (
  <!-- 02 ALL EPISODES -->
  <section class="sec wrap">
    <div class="row2">
      <div class="spine">
        <span class="no">02</span>
        <span class="lab">Episodes</span>
        <span class="note">全部单集，按期号倒序。</span>
      </div>
      <div class="ep-list">
        {archive.map((ep: Episode) => (
          <article class="ep-item" id={`ep-${ep.slug}`}>
            <span class="ep-eyebrow">{episodeMeta(ep)}</span>
            <div class="ep-title-row">
              <h3 class="ep-title">{ep.title}</h3>
              <button type="button" class="ep-share" data-ep-slug={ep.slug} title="分享本集" aria-label="分享本集">
                <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 16V4"/><path d="m8 8 4-4 4 4"/><path d="M5 12v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6"/>
                </svg>
              </button>
            </div>
            {epBlurb(ep) && <p class="ep-sum">{epBlurb(ep)}</p>}
            <audio controls preload="none" src={`/api/podcasts/episodes/${encodeURIComponent(ep.slug)}/download`}></audio>
            {ep.transcript && (
              <div class="tx" data-slug={ep.slug} data-api-url={apiUrl}>
                <button type="button" class="tx-toggle" aria-expanded="false">逐字稿<span class="tx-caret">▾</span></button>
                <div class="tx-panel" hidden>
                  <div class="tx-body"></div>
                </div>
              </div>
            )}
            <div class="ep-fb" data-slug={ep.slug} data-api-url={apiUrl}>
              <div class="ep-fb-chips">
                {FEEDBACK_CHIPS.map((chip) => (
                  <button type="button" class="ep-fb-chip" data-category={chip.category}>{chip.label}</button>
                ))}
                <button type="button" class="ep-fb-say">说一句</button>
              </div>
              <input class="ep-fb-note msg-hidden" type="text" maxlength="200" placeholder="一句话（可选）" />
              <p class="ep-fb-hint msg-hidden">写完，点上面任一个表情发出去</p>
              <p class="ep-fb-msg msg-hidden"></p>
              <p class="ep-fb-thanks msg-hidden">已收到 · 谢谢</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

</BaseLayout>

<script>
  import { categoryToReaction } from '../lib/feedback';
  import { segmentTranscript, blockAtProgress, type TxBlock } from '../lib/transcript';

  // A submission locks this episode's control on THIS browser for 24h. After that
  // the chips return, so a re-listen the next day can leave fresh feedback.
  const FB_TTL_MS = 24 * 60 * 60 * 1000;
  // The "已收到 · 谢谢" acknowledgment is transient: it confirms the submit, then
  // fades away — the feedback is recorded, so the line need not linger.
  const FB_DISMISS_MS = 30 * 1000;
  const fbKey = (slug: string) => `wb_ep_fb_${slug}`;

  function alreadyGiven(slug: string): boolean {
    try {
      const raw = localStorage.getItem(fbKey(slug));
      if (!raw) return false;
      const { ts } = JSON.parse(raw) as { ts?: number };
      if (typeof ts !== 'number' || Date.now() - ts >= FB_TTL_MS) {
        localStorage.removeItem(fbKey(slug));
        return false;
      }
      return true;
    } catch {
      return false; // private mode / storage disabled → degrade to no memory
    }
  }

  function remember(slug: string, category: string): void {
    try {
      localStorage.setItem(fbKey(slug), JSON.stringify({ ts: Date.now(), category }));
    } catch { /* storage unavailable — nothing to persist, server dedup still guards */ }
  }

  function hide(root: HTMLElement): void {
    root.style.display = 'none';
  }

  // Reveal the pre-rendered acknowledgment and hide the interactive controls,
  // then fade it out and collapse. NOTE: the <p class="ep-fb-thanks"> lives in
  // the template (not injected via innerHTML) so Astro's scoped styles — which
  // match on a data-astro-cid attribute only present on build-time elements —
  // actually apply to it. Injecting it at runtime silently dropped the styling.
  function showThanks(root: HTMLElement): void {
    root.querySelectorAll<HTMLElement>('.ep-fb-chips, .ep-fb-note, .ep-fb-hint, .ep-fb-msg')
      .forEach((el) => el.classList.add('msg-hidden'));
    const thanks = root.querySelector<HTMLElement>('.ep-fb-thanks');
    if (!thanks) { hide(root); return; }
    thanks.classList.remove('msg-hidden');
    window.setTimeout(() => {
      thanks.classList.add('ep-fb-thanks--out');
      window.setTimeout(() => hide(root), 400);
    }, FB_DISMISS_MS);
  }

  function wireFeedback(root: HTMLElement) {
    const slug = root.dataset.slug;
    const apiUrl = root.dataset.apiUrl;
    if (!slug || !apiUrl) return;

    // Within the 24h window this browser already gave feedback → hide the
    // control entirely. The acknowledgment was transient; on reload there is
    // nothing to show until the window lapses and the chips return.
    if (alreadyGiven(slug)) { hide(root); return; }

    const noteInput = root.querySelector<HTMLInputElement>('.ep-fb-note')!;
    const sayBtn = root.querySelector<HTMLButtonElement>('.ep-fb-say')!;
    const msgEl = root.querySelector<HTMLElement>('.ep-fb-msg')!;
    const chips = root.querySelectorAll<HTMLButtonElement>('.ep-fb-chip');

    // Optional note stays collapsed until the listener opts in — keeps the
    // resting state to a quiet row of chips. Tapping a chip still submits in one
    // step, with whatever note has been typed (empty if never revealed).
    sayBtn.addEventListener('click', () => {
      noteInput.classList.remove('msg-hidden');
      // Persistent send hint — the placeholder vanishes on input, so a standing
      // line tells the listener a chip tap (above) is what sends the note.
      root.querySelector<HTMLElement>('.ep-fb-hint')?.classList.remove('msg-hidden');
      sayBtn.classList.add('msg-hidden');
      noteInput.focus();
    });

    chips.forEach((btn) => {
      btn.addEventListener('click', async () => {
        const category = btn.dataset.category!;
        const reaction = categoryToReaction(category as Parameters<typeof categoryToReaction>[0]);
        const note = noteInput.value.trim() || undefined;
        chips.forEach((b) => (b.disabled = true));
        noteInput.disabled = true;
        sayBtn.disabled = true;
        try {
          const res = await fetch(
            `${apiUrl}/api/podcasts/episodes/${encodeURIComponent(slug)}/feedback`,
            {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ reaction, category, note }),
            },
          );
          if (res.ok) {
            remember(slug, category);
            showThanks(root);
          } else {
            throw new Error('non-ok');
          }
        } catch {
          msgEl.textContent = '提交失败，稍后再试';
          msgEl.classList.remove('msg-hidden');
          chips.forEach((b) => (b.disabled = false));
          noteInput.disabled = false;
          sayBtn.disabled = false;
        }
      });
    });
  }

  // Transcript wiring: per-episode expand/fetch/highlight/scroll/seek.
  // Independent of wireFeedback — preserves `<audio preload="none">` (download
  // counting depends on it) and never touches `.ep-fb*` elements.
  const TX_SCROLL_PAUSE_MS = 4000; // user manual scroll pauses auto-scroll for this long

  async function wireTranscript(root: HTMLElement) {
    const slug = root.dataset.slug;
    const apiUrl = root.dataset.apiUrl;
    if (!slug || !apiUrl) return;
    const toggle = root.querySelector<HTMLButtonElement>('.tx-toggle')!;
    const panel = root.querySelector<HTMLDivElement>('.tx-panel')!;
    const body = root.querySelector<HTMLDivElement>('.tx-body')!;
    const audio = root.closest('.ep-item')?.querySelector<HTMLAudioElement>('audio');
    if (!audio) return;

    let blocks: TxBlock[] = [];
    let lineEls: HTMLElement[] = [];
    let loaded = false;
    let inFlight = false; // a fetch is in-flight — guards concurrent re-entry without latching on error
    let activeIdx = -1;
    let userScrolledAt = 0;
    let suppressScrollUntil = 0; // scroll events fired before this timestamp are treated as program-initiated and ignored

    toggle.addEventListener('click', async () => {
      const open = panel.hasAttribute('hidden');
      if (open) {
        panel.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        if (!loaded && !inFlight) await load();
      } else {
        panel.setAttribute('hidden', '');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    async function load() {
      inFlight = true;
      try {
        const res = await fetch(`${apiUrl}/api/podcasts/episodes/${encodeURIComponent(slug!)}/transcript.txt`);
        if (!res.ok) throw new Error('non-ok');
        blocks = segmentTranscript(await res.text());
        body.innerHTML = ''; // injected .tx-line nodes lack data-astro-cid → :global styles (Pre-flight risk)
        lineEls = blocks.map((b, i) => {
          const p = document.createElement('p');
          p.className = 'tx-line' + (b.isHeading ? ' tx-line--h' : '');
          p.textContent = b.text;
          p.dataset.i = String(i);
          p.addEventListener('click', () => seekTo(i));
          body.appendChild(p);
          return p;
        });
        loaded = true; // latch only on success — an error leaves loaded=false so a re-expand retries
      } catch {
        body.innerHTML = '<p class="tx-empty">逐字稿加载失败</p>';
      } finally {
        inFlight = false;
      }
    }

    function seekTo(i: number) {
      const ratio = blocks[i]?.startRatio ?? 0;
      const apply = () => { if (isFinite(audio!.duration)) audio!.currentTime = ratio * audio!.duration; };
      if (isFinite(audio!.duration) && audio!.duration > 0) {
        apply(); audio!.play().catch(() => {});
      } else {
        audio!.addEventListener('loadedmetadata', apply, { once: true });
        audio!.play().catch(() => {}); // preload=none: play() triggers load — equivalent to a user press, legitimate /download hit
      }
    }

    audio.addEventListener('timeupdate', () => {
      if (panel.hasAttribute('hidden') || !loaded || lineEls.length === 0) return;
      if (!isFinite(audio.duration) || audio.duration <= 0) return;
      const idx = blockAtProgress(blocks, audio.currentTime / audio.duration);
      if (idx === activeIdx) return;
      if (activeIdx >= 0) lineEls[activeIdx]?.classList.remove('is-active');
      activeIdx = idx;
      const el = lineEls[idx];
      if (!el) return;
      el.classList.add('is-active');
      if (Date.now() - userScrolledAt > TX_SCROLL_PAUSE_MS) {
        suppressScrollUntil = Date.now() + 250; // program-initiated scroll event falls in this window
        // Center the active line. Use getBoundingClientRect deltas, not el.offsetTop —
        // offsetTop is relative to the offsetParent (the panel is not positioned, so
        // that's <body>), which would scroll to a wildly wrong, page-relative position.
        const elRect = el.getBoundingClientRect();
        const panelRect = panel.getBoundingClientRect();
        panel.scrollTop += (elRect.top - panelRect.top) - (panel.clientHeight - el.clientHeight) / 2;
      }
    });

    // Time-window approach for distinguishing program vs. user scrolls: the
    // assignment above opens a 250ms suppression window during which all scroll
    // events are ignored; events outside the window are user-initiated → pause
    // auto-scroll for TX_SCROLL_PAUSE_MS. The window covers both failure modes
    // of a boolean pair: (a) assignment leaves scrollTop unchanged → no scroll
    // event (window expires harmlessly); (b) hypothetical smooth scrolling would
    // fire multiple events (all swallowed inside the window — smooth disabled
    // above regardless).
    panel.addEventListener('scroll', () => {
      if (Date.now() < suppressScrollUntil) return;
      userScrolledAt = Date.now();
    });
  }

  document.querySelectorAll<HTMLElement>('.ep-fb').forEach(wireFeedback);
  document.querySelectorAll<HTMLElement>('.tx').forEach((el) => { void wireTranscript(el); });

  // Per-episode share: links to /podcast#ep-<slug>. Mobile uses the system
  // share sheet (target=native), desktop copies the anchor link (target=copy).
  // The episode identity rides in the path (#ep-slug), not the target column.
  function trackShare(path: string, target: string) {
    const apiUrl = document.body.dataset.apiUrl;
    if (!apiUrl) return;
    fetch(`${apiUrl}/api/analytics/share`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path, target }),
      keepalive: true,
    }).catch(() => {});
  }

  document.querySelectorAll<HTMLButtonElement>('.ep-share').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const slug = btn.dataset.epSlug;
      if (!slug) return;
      const path = `/podcast#ep-${slug}`;
      const url = `${location.origin}${path}`;
      if (typeof navigator.share === 'function') {
        trackShare(path, 'native');
        navigator.share({ url }).catch(() => {});
        return;
      }
      trackShare(path, 'copy');
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        const input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
      // Icon-only feedback: swap the share glyph for a checkmark for ~1.3s.
      const svg = btn.querySelector('svg');
      if (svg) {
        const orig = svg.innerHTML;
        svg.innerHTML = '<path d="M20 6 9 17l-5-5"/>';
        btn.classList.add('copied');
        setTimeout(() => { svg.innerHTML = orig; btn.classList.remove('copied'); }, 1300);
      }
    });
  });
</script>

<style>
  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }

  /* ── Eyebrow ──────────────────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 22px;
  }

  /* ── Buttons ──────────────────────────────────────────────────────────────── */
  .btn {
    font-family: var(--font-ui); font-size: 15px; font-weight: 600;
    cursor: pointer; padding: 12px 20px; border-radius: 99px;
    border: 1px solid transparent;
    transition: transform .18s var(--ease), background .2s, border-color .2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn-1 { background: var(--accent); color: var(--on-accent); }
  .btn-2 { background: transparent; color: var(--ink); border-color: var(--line-2); }
  .btn-2:hover { border-color: var(--ink-3); background: var(--surface-2); }

  /* ── Subscribe (stacked under the cover in the show-id column) ────────────── */
  .subscribe { display: flex; flex-direction: column; align-items: flex-start; gap: 10px; }

  /* ── Show header (00 HERO) ────────────────────────────────────────────────── */
  /* Cover-left, identity-right (Apple show-header). To flip the cover to the
     right, change grid-template-columns to `1fr auto` and reorder is automatic
     since .show-cover comes first in source — move it after .show-meta instead. */
  /* Eyebrow is a full-width kicker on top; the cover+subscribe column and the
     identity (title + lede) column below it start at the same line, so the
     icon/RSS top-align with the title and body, not with the small eyebrow. */
  .show-body {
    display: grid; grid-template-columns: auto 1fr;
    gap: clamp(20px, 3vw, 36px); align-items: start;
  }
  /* Left column: cover + subscribe stacked, top-aligned with the identity text. */
  .show-id { display: flex; flex-direction: column; gap: 20px; align-items: flex-start; }
  .show-cover {
    width: clamp(112px, 13vw, 132px); aspect-ratio: 1;
    border-radius: var(--r-lg); flex-shrink: 0; overflow: hidden;
    background: radial-gradient(120% 120% at 20% 0%, color-mix(in srgb, var(--accent) 50%, #15151a), #0e0e14);
    display: grid; place-items: center; box-shadow: var(--shadow);
  }
  .show-cover img { width: 100%; height: 100%; object-fit: cover; }
  .show-cover span {
    font-family: var(--font-display); font-weight: 700;
    font-size: 38px; color: #fff; letter-spacing: -.03em;
  }
  .show-meta h1 {
    margin: 0;
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(28px, 3.4vw, 40px); line-height: 1.12; letter-spacing: -.02em;
  }

  /* ── Episode rows (01 Latest + 02 Episodes share this) ────────────────────── */
  .ep-list { display: flex; flex-direction: column; }
  .ep-item {
    display: flex; flex-direction: column; align-items: flex-start;
    gap: 10px; padding: 26px 0; border-top: 1px solid var(--line);
  }
  .ep-item:first-child { border-top: none; padding-top: 2px; }
  .ep-eyebrow {
    font-family: var(--font-mono); font-size: 11.5px;
    letter-spacing: .1em; text-transform: uppercase; color: var(--ink-3);
  }
  .ep-eyebrow--accent { color: var(--accent); }
  .ep-title {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(18px, 1.7vw, 21px); letter-spacing: -.02em;
    line-height: 1.3; margin: 0;
  }
  /* The featured (latest) episode reads larger than the archive rows. */
