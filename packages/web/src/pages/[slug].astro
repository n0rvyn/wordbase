---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompanionBody from '../components/page-bodies/CompanionBody.astro';
import { getPages, type Page } from '../lib/api';
import { marked } from 'marked';

export async function getStaticPaths() {
  const pages = await getPages();
  return pages
    .filter((p: Page) => p.status === 'published')
    .map((p: Page) => ({
      params: { slug: p.slug },
      props: { page: p },
    }));
}

interface Props {
  page: Page;
}

const { page } = Astro.props;
const htmlContent = marked.parse(page.content) as string;
---

<BaseLayout title={page.title} hasEnTwin>
  <CompanionBody title={page.title} htmlContent={htmlContent} />
</BaseLayout>
