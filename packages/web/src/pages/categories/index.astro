---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoriesIndexBody from '../../components/page-bodies/CategoriesIndexBody.astro';
import { getCategories, getPosts } from '../../lib/api';
import { t } from '../../lib/i18n.js';

const categories = await getCategories();
const catCounts = new Map<string, number>();
for (const cat of categories) {
  const { data } = await getPosts({ status: 'published', category: cat.slug, limit: 10000 });
  catCounts.set(cat.slug, data.length);
}
---

<BaseLayout title="分类" titleEn={t('title.categories').en} description="全部文章分类。" hasEnTwin>
  <CategoriesIndexBody locale="zh" categories={categories} catCounts={catCounts} />
</BaseLayout>
