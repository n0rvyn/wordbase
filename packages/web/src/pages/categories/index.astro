---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategories, type Category } from '../../lib/api';

const categories = await getCategories();
---

<BaseLayout title="分类">
  <header class="page-header">
    <h1 class="page-title">分类</h1>
    <p class="page-subtitle">{categories.length} 个分类</p>
  </header>

  {categories.length === 0 ? (
    <p class="empty">暂无分类</p>
  ) : (
    <div class="category-grid">
      {categories.map((cat: Category) => (
        <a href={`/categories/${cat.slug}`} class="category-card">
          <span class="category-name">{cat.name}</span>
          {cat.description && <span class="category-desc">{cat.description}</span>}
          <span class="category-arrow" aria-hidden="true">&rarr;</span>
        </a>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  .page-header { margin-bottom: 3rem; }
  .page-title { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
  .page-subtitle { font-family: var(--font-sans); font-size: 0.85rem; color: var(--color-ink-faint); }
  .empty { color: var(--color-ink-faint); }

  .category-grid {
    display: grid;
    gap: 1px;
    background: var(--color-rule);
    border: 1px solid var(--color-rule);
    border-radius: 12px;
    overflow: hidden;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.5rem;
    background: var(--color-paper-white);
    transition: background 0.2s ease;
    position: relative;
  }

  .category-card:hover {
    background: var(--color-paper-warm);
  }

  .category-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  .category-desc {
    font-size: 0.85rem;
    color: var(--color-ink-faint);
    line-height: 1.5;
  }

  .category-arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--color-ink-ghost);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .category-card:hover .category-arrow {
    transform: translateX(4px);
    color: var(--color-vermillion);
  }
</style>
