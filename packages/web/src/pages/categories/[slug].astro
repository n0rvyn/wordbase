---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategories, getPosts, estimateReadTime, stripMarkdown, type Category, type Post } from '../../lib/api';
import { formatMonoDate, decodeEntities } from '../../lib/home';
import T from '../../components/T.astro';

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map((cat: Category) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

interface Props {
  category: Category;
}

const { category } = Astro.props;
const { data: posts } = await getPosts({ status: 'published', category: category.slug, limit: 10000 });
const sorted = [...posts].sort((a, b) => (b.publishedAt ?? 0) - (a.publishedAt ?? 0));
const catName = decodeEntities(category.name);
---

<BaseLayout title={catName} description={category.description || undefined}>

<header class="sec wrap" style="border-top:none;padding-top:clamp(44px,6vw,80px)">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">Category</span>
      <span class="note"><T zh={`${sorted.length} 篇文章。`} en={`${sorted.length} posts.`} /></span>
    </div>
    <div>
      <div class="eyebrow"><T k="cat.detail.eyebrow" /></div>
      <h1>{catName}</h1>
      {category.description && <p class="lede-w">{category.description}</p>}
    </div>
  </div>
</header>

<section class="sec wrap">
  <div class="row2">
    <div class="spine">
      <span class="no">01</span>
      <span class="lab"><T k="cat.detail.posts.lab" /></span>
    </div>
    <div>
      {sorted.length === 0 ? (
        <div class="empty"><T k="cat.detail.empty" /></div>
      ) : (
        <div class="list">
          {sorted.map((p: Post) => (
            <a class="item post" href={`/posts/${p.slug}`}>
              <div>
                {p.publishedAt && <div class="pdate">{formatMonoDate(p.publishedAt)}</div>}
                <div class="item-title">{p.title}</div>
                <div class="item-sub">{p.excerpt || stripMarkdown(p.content, 120)}</div>
              </div>
              <div class="item-meta">{estimateReadTime(p.content)} min</div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

</BaseLayout>

<style>
  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }

  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 20px;
  }
  h1 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(40px, 6vw, 76px); line-height: 1.02;
    letter-spacing: -.035em; margin: 0 0 22px;
  }
  .lede-w {
    font-family: var(--font-read); font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.75; color: var(--ink-2); max-width: 46ch; margin: 0;
  }

  /* ── Empty state ──────────────────────────────────────────────────────────── */
  .empty { font-family: var(--font-read); color: var(--ink-3); font-size: 16px; padding: 48px 0; }

  /* ── Full-density post rows ───────────────────────────────────────────────── */
  .post { grid-template-columns: 1fr auto; gap: 6px 28px; }
  .post .item-title { font-size: clamp(19px, 2vw, 24px); margin-bottom: 6px; }
  .pdate {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--ink-3); margin-bottom: 9px;
  }
  .post .item-sub { font-size: 15px; }
  .post .item-meta { align-self: start; padding-top: 2px; }
</style>
