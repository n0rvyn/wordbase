---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArchivesBody from '../components/page-bodies/ArchivesBody.astro';
import { loadArchivesData } from '../lib/writing';
import { t } from '../lib/i18n.js';

const { groups, totalPosts } = await loadArchivesData('zh');
---

<BaseLayout title="归档" titleEn={t('title.archives').en} hasEnTwin description="全部文章，按时间倒序。">
  <ArchivesBody locale="zh" groups={groups} totalPosts={totalPosts} />
</BaseLayout>
