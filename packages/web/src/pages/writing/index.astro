---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getPosts,
  getCategories,
  estimateReadTime,
  stripMarkdown,
  type Post,
} from '../../lib/api';
import { formatMonoDate, decodeEntities } from '../../lib/home';
import {
  selectTopCategories,
  groupByYear,
  selectFullYears,
  densityForYear,
} from '../../lib/writing';
import T from '../../components/T.astro';
import { t } from '../../lib/i18n.js';

// ── Fetch all published posts sorted desc ────────────────────────────────────
const { data: postsRaw } = await getPosts({ status: 'published', limit: 10000 });
const posts = [...postsRaw].sort((a, b) => (b.publishedAt ?? 0) - (a.publishedAt ?? 0));

// ── Build per-post category slug list + per-category count ───────────────────
const cats = await getCategories();
const postCatSlugs = new Map<string, string[]>(); // post id → all category slugs
const catCount = new Map<string, number>();        // category slug → published count

for (const cat of cats) {
  const { data: catPosts } = await getPosts({ status: 'published', category: cat.slug, limit: 10000 });
  catCount.set(cat.slug, catPosts.length);
  for (const p of catPosts) {
    const existing = postCatSlugs.get(p.id) ?? [];
    if (!existing.includes(cat.slug)) existing.push(cat.slug);
    postCatSlugs.set(p.id, existing);
  }
}

// ── Top categories for chips ─────────────────────────────────────────────────
const catInputs = cats.map(c => ({
  slug: c.slug,
  name: c.name,
  count: catCount.get(c.slug) ?? 0,
}));
const topCats = selectTopCategories(catInputs, 6);

// ── Featured (newest post) + archive (rest) ──────────────────────────────────
const featured = posts[0] ?? null;
const archive = posts.slice(1);

// Featured variant per active filter: 'all' = newest overall; each top category
// = its newest post. The chip filter swaps which variant is shown.
const featuredVariants = ([
  { key: 'all', post: featured },
  ...topCats.map(c => ({
    key: c.slug,
    post: posts.find(p => (postCatSlugs.get(p.id) ?? []).includes(c.slug)) ?? null,
  })),
].filter(v => v.post) as { key: string; post: Post }[]);
const fullYears = selectFullYears(posts, 2);
const groups = groupByYear(archive);

// ── Helper: first category name for a post ───────────────────────────────────
function firstCatName(p: Post): string {
  const slugs = postCatSlugs.get(p.id) ?? [];
  if (slugs.length === 0) return '';
  const cat = cats.find(c => c.slug === slugs[0]);
  return cat ? decodeEntities(cat.name) : '';
}
---

<BaseLayout title="写作" titleEn={t('title.writing').en} description="关于设计取舍、工程实践与独立开发。">

<!-- HERO -->
<header class="sec wrap" style="border-top:none;padding-top:clamp(44px,6vw,80px)">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">Writing</span>
      <span class="note"><T k="writing.spine.note" /></span>
    </div>
    <div>
      <div class="eyebrow"><T k="writing.eyebrow" /></div>
      <h1><T k="writing.h1" /></h1>
      <p class="lede-w"><T k="writing.lede" /></p>
      <div class="topics">
        <button class="chip-f sel" data-cat="all"><T k="writing.chipAll" /></button>
        {topCats.map(cat => (
          <button class="chip-f" data-cat={cat.slug}>{cat.name}</button>
        ))}
        <a class="viewall" href="/categories"><T k="writing.viewallCats" /></a>
      </div>
    </div>
  </div>
</header>

<!-- FEATURED -->
{featured && (
  <section class="sec wrap">
    <div class="row2">
      <div class="spine">
        <span class="no">01</span>
        <span class="lab">Latest</span>
        <span class="note"><T k="writing.featured.note" /></span>
      </div>
      <div class="feat-stack">
        {featuredVariants.map(({ key, post }) => (
          <a
            class={`post-feat${key === 'all' ? '' : ' hide'}`}
            data-feat-cat={key}
            data-feat-id={post.id}
            href={`/posts/${post.slug}`}
          >
            <span class="tag"><T k="writing.featured.tag" /></span>
            {post.publishedAt && <div class="pdate">{formatMonoDate(post.publishedAt)}</div>}
            <h2>{post.title}</h2>
            <p>{post.excerpt || stripMarkdown(post.content, 160)}</p>
            <div class="rmeta">
              <span class="item-meta">
                {[firstCatName(post), `${estimateReadTime(post.content)} min`].filter(Boolean).join(' · ')}
              </span>
              <span class="read-link"><T k="writing.readMore" /> <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ARCHIVE -->
<section class="sec wrap">
  <div class="row2">
    <div class="spine">
      <span class="no">02</span>
      <span class="lab">Archive</span>
      <span class="note"><T k="writing.archive.note" /></span>
    </div>
    <div id="postList">
      {groups.map(group => {
        const density = densityForYear(group.year, fullYears);
        return (
          <div class="year-section">
            <div class="year-head">
              <span class="mono">{group.year === 0 ? <T k="writing.yearUnknown" /> : group.year}</span>
            </div>
            <div class="list">
              {group.posts.map((p: Post) => {
                const slugs = postCatSlugs.get(p.id) ?? [];
                const catName = firstCatName(p);
                return (
                  <a
                    class={`item post ${density}`}
                    data-id={p.id}
                    data-cats={slugs.join(' ')}
                    href={`/posts/${p.slug}`}
                  >
                    {density === 'full' ? (
                      <div>
                        {p.publishedAt && <div class="pdate">{formatMonoDate(p.publishedAt)}</div>}
                        <div class="item-title">{p.title}</div>
                        <div class="item-sub">{p.excerpt || stripMarkdown(p.content, 120)}</div>
                      </div>
                    ) : (
                      <div class="compact-inner">
                        {p.publishedAt && <span class="pdate compact-date">{formatMonoDate(p.publishedAt)}</span>}
                        <span class="item-title compact-title">{p.title}</span>
                        {catName && <span class="item-meta compact-cat">{catName}</span>}
                      </div>
                    )}
                    {density === 'full' && (
                      <div class="item-meta">
                        {[`${estimateReadTime(p.content)} min`, catName].filter(Boolean).join(' · ')}
                      </div>
                    )}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

</BaseLayout>

<script>
  // ── Chip filter ──────────────────────────────────────────────────────────────
  const featBlocks = document.querySelectorAll<HTMLElement>('.post-feat[data-feat-cat]');

  document.querySelectorAll<HTMLButtonElement>('.chip-f').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.chip-f').forEach(c => c.classList.remove('sel'));
      chip.classList.add('sel');
      const cat = chip.dataset.cat ?? 'all';

      // Swap the featured (01) block to the active category's newest post.
      // Fall back to the 'all' variant if a category has no featured block.
      let activeFeatId: string | null = null;
      let matched = false;
      featBlocks.forEach(fb => {
        const isMatch = fb.dataset.featCat === cat;
        if (isMatch) { matched = true; activeFeatId = fb.dataset.featId ?? null; }
      });
      featBlocks.forEach(fb => {
        const show = matched
          ? fb.dataset.featCat === cat
          : fb.dataset.featCat === 'all';
        fb.classList.toggle('hide', !show);
      });
      if (!matched) activeFeatId = null;

      document.querySelectorAll<HTMLElement>('.item.post[data-cats]').forEach(row => {
        const rowCats = (row.dataset.cats ?? '').split(' ');
        const hide =
          (cat !== 'all' && !rowCats.includes(cat)) ||
          (activeFeatId !== null && row.dataset.id === activeFeatId);
        row.classList.toggle('hide', hide);
      });

      // Hide year headings with no visible posts
      document.querySelectorAll<HTMLElement>('.year-section').forEach(section => {
        const visiblePosts = section.querySelectorAll('.item.post:not(.hide)');
        (section.querySelector('.year-head') as HTMLElement | null)?.classList.toggle(
          'hide',
          visiblePosts.length === 0,
        );
      });
    });
  });
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 20px;
  }
  h1 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(40px, 6vw, 76px); line-height: 1.02;
    letter-spacing: -.035em; margin: 0 0 22px;
  }
  .lede-w {
    font-family: var(--font-read); font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.75; color: var(--ink-2); max-width: 46ch; margin: 0;
  }

  /* ── Topic chips ──────────────────────────────────────────────────────────── */
  .topics {
    display: flex; gap: 8px; flex-wrap: wrap; margin-top: 26px; align-items: center;
  }
  .chip-f {
    font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .06em;
    text-transform: uppercase; color: var(--ink-2); background: transparent;
    border: 1px solid var(--line-2); border-radius: 99px; padding: 8px 15px;
    cursor: pointer; transition: all .2s var(--ease);
  }
  .chip-f:hover { border-color: var(--ink-3); color: var(--ink); }
  .chip-f.sel { background: var(--accent); color: var(--on-accent); border-color: var(--accent); }

  /* ── View all link ────────────────────────────────────────────────────────── */
  .viewall {
    display: inline-flex; align-items: center; gap: 7px;
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--accent); font-weight: 500;
    transition: gap .2s var(--ease); margin-left: 4px;
  }
  .viewall:hover { gap: 11px; }

  /* ── Featured post ────────────────────────────────────────────────────────── */
  .post-feat {
    display: block;
    /* Same 14px hover slide as the archive rows, but via transform (not
       padding) so the content width never changes — padding-left would
       shrink the measure and reflow the long excerpt's line breaks. */
    transition: transform .3s var(--ease);
  }
  .post-feat .tag {
    font-family: var(--font-mono); font-size: 11.5px;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 16px; display: block;
  }
  .post-feat .pdate {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--ink-3); margin-bottom: 14px;
  }
  .post-feat h2 {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(28px, 3.6vw, 46px); letter-spacing: -.03em;
    line-height: 1.08; margin: 0 0 16px; max-width: var(--measure);
    transition: color .2s var(--ease);
  }
  .post-feat p {
    font-family: var(--font-read); font-size: 17px; line-height: 1.75;
    color: var(--ink-2); max-width: var(--measure); margin: 0 0 22px;
  }
  .post-feat .rmeta { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
  .post-feat .rmeta .item-meta { font-size: 11.5px; }
  .read-link {
    font-weight: 600; color: var(--accent);
    display: inline-flex; align-items: center; gap: 7px; font-size: 15px;
  }
  .read-link svg { width: 15px; height: 15px; transition: transform .2s var(--ease); }
  .post-feat:hover { transform: translateX(14px); }
  .post-feat:hover h2 { color: var(--accent); }
  .post-feat:hover .read-link svg { transform: translateX(3px); }

  /* ── Shared list row language ─────────────────────────────────────────────── */
  .list { display: flex; flex-direction: column; }
  .item {
    display: grid; align-items: center;
    padding: 22px 4px; border-top: 1px solid var(--line);
    transition: padding-left .3s var(--ease), margin-right .3s var(--ease);
  }
  .item:first-child { border-top: none; padding-top: 2px; }
  /* padding slide + equal negative margin-right = no width change, no reflow,
     hairline stays put (see BaseLayout .item for the full rationale). */
  .item:hover { padding-left: 14px; margin-right: -10px; }
  .item-title {
    font-family: var(--font-display); font-weight: 600;
    letter-spacing: -.018em; transition: color .2s;
  }
  .item:hover .item-title { color: var(--accent); }
  .item-sub { color: var(--ink-2); font-family: var(--font-read); }
  .item-meta {
    font-family: var(--font-mono); font-size: 11.5px;
    letter-spacing: .05em; color: var(--ink-3); white-space: nowrap;
  }

  /* ── Full-density post rows ───────────────────────────────────────────────── */
  .post.full { grid-template-columns: 1fr auto; gap: 6px 28px; }
  .post.full .item-title { font-size: clamp(19px, 2vw, 24px); margin-bottom: 6px; }
  .post.full .pdate {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--ink-3); margin-bottom: 9px;
  }
  .post.full .item-sub { font-size: 15px; }
  .post.full .item-meta { align-self: start; padding-top: 2px; }

  /* ── Compact post rows ────────────────────────────────────────────────────── */
  .post.compact { grid-template-columns: 1fr; }
  .compact-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 0 16px;
    align-items: baseline;
  }
  .compact-date {
    font-family: var(--font-mono); font-size: 11.5px;
    color: var(--ink-3); white-space: nowrap;
  }
  .compact-title {
    font-family: var(--font-display); font-weight: 600;
    font-size: 16px; letter-spacing: -.018em; transition: color .2s;
  }
  .item:hover .compact-title { color: var(--accent); }
  .compact-cat {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ink-3); white-space: nowrap; text-align: right;
  }

  /* ── Year heading ─────────────────────────────────────────────────────────── */
  .year-head {
    padding: 28px 4px 8px;
    border-top: 1px solid var(--line);
  }
  .year-head .mono {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .13em; text-transform: uppercase;
    color: var(--ink-3);
  }
  .year-section:first-child .year-head { border-top: none; }

  /* ── Hide ─────────────────────────────────────────────────────────────────── */
  .hide { display: none; }

  /* ── Responsive ───────────────────────────────────────────────────────────── */
  @media (max-width: 560px) {
    .compact-inner { grid-template-columns: 1fr auto; }
    .compact-date { display: none; }
    /* Full rows: stop floating the meta far-right (the 1fr column gets too
       narrow on phones, leaving "N min · Tag" disconnected). Stack it under
       the excerpt, left-aligned, in reading order. */
    .post.full { grid-template-columns: 1fr; }
    .post.full .item-meta { align-self: start; padding-top: 10px; }
  }
</style>
