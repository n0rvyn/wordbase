---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPosts, formatDate, stripMarkdown, estimateReadTime, type Post } from '../../lib/api';

export const getStaticPaths = (async ({ paginate }) => {
  const { data: posts } = await getPosts({ status: 'published', limit: 10000 });
  const sorted = posts.sort((a, b) => (b.publishedAt || 0) - (a.publishedAt || 0));
  return paginate(sorted, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout title={`第 ${page.currentPage} 页`}>
  <div class="post-list">
    {page.data.map((post: Post, i: number) => (
      <article class="post-item" style={`animation-delay: ${i * 50}ms`}>
        <div class="post-date">
          {post.publishedAt && (
            <time datetime={new Date(post.publishedAt * 1000).toISOString()}>
              {new Date(post.publishedAt * 1000).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}
            </time>
          )}
        </div>
        <div class="post-body">
          <h2 class="post-title">
            <a href={`/posts/${post.slug}`}>{post.title}</a>
          </h2>
          <p class="post-excerpt">{post.excerpt || stripMarkdown(post.content, 120)}</p>
        </div>
        <span class="post-readtime">{estimateReadTime(post.content)} min</span>
      </article>
    ))}
  </div>

  <nav class="page-nav">
    {page.url.prev ? (
      <a href={page.currentPage === 2 ? '/' : page.url.prev} class="nav-btn">
        <span>&larr;</span> 较新
      </a>
    ) : (
      <a href="/" class="nav-btn"><span>&larr;</span> 首页</a>
    )}
    <span class="nav-current">{page.currentPage} / {page.lastPage}</span>
    {page.url.next ? (
      <a href={page.url.next} class="nav-btn">较旧 <span>&rarr;</span></a>
    ) : <span class="nav-btn" style="visibility: hidden">placeholder</span>}
  </nav>
</BaseLayout>

<style>
  .post-list { display: flex; flex-direction: column; }

  .post-item {
    display: grid;
    grid-template-columns: 70px 1fr auto;
    gap: 1.25rem;
    align-items: baseline;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-rule);
    animation: fadeUp 0.5s ease both;
    transition: background 0.2s ease;
  }

  .post-item:first-child { border-top: 1px solid var(--color-rule); }

  .post-item:hover {
    background: var(--color-paper-warm);
    margin: 0 -1rem;
    padding-left: 1rem;
    padding-right: 1rem;
    border-radius: 8px;
    border-color: transparent;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-ink-ghost);
    white-space: nowrap;
    padding-top: 0.15rem;
  }

  .post-body { min-width: 0; }

  .post-title {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.35rem;
  }

  .post-title a:hover { color: var(--color-vermillion); }

  .post-excerpt {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-ink-faint);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-readtime {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-ink-ghost);
    white-space: nowrap;
    padding-top: 0.15rem;
  }

  .page-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-rule);
  }

  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-ink-faint);
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--color-rule);
    border-radius: 100px;
    transition: all 0.2s ease;
  }

  .nav-btn:hover {
    color: var(--color-ink);
    border-color: var(--color-ink-faint);
  }

  .nav-current {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-ink-ghost);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .post-item { grid-template-columns: 1fr; gap: 0.25rem; }
    .post-date, .post-readtime { display: none; }
  }
</style>
