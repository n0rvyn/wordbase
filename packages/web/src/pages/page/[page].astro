---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PagerBody from '../../components/page-bodies/PagerBody.astro';
import { getPosts } from '../../lib/api';
import { t } from '../../lib/i18n.js';

export const getStaticPaths = (async ({ paginate }) => {
  const { data: posts } = await getPosts({ status: 'published', limit: 10000 });
  const sorted = posts.sort((a, b) => (b.publishedAt || 0) - (a.publishedAt || 0));
  return paginate(sorted, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout title={`第 ${page.currentPage} 页`} titleEn={t('title.page').en.replace('{n}', String(page.currentPage))} hasEnTwin>
  <PagerBody
    locale="zh"
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    posts={page.data}
    urlPrev={page.url.prev}
    urlNext={page.url.next}
  />
</BaseLayout>
