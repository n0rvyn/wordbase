---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagsIndexBody from '../../components/page-bodies/TagsIndexBody.astro';
import { getTags } from '../../lib/api';
import { t } from '../../lib/i18n.js';

const tags = await getTags();
---

<BaseLayout title="标签" titleEn={t('title.tags').en} description="全部文章标签。" hasEnTwin>
  <TagsIndexBody locale="zh" tags={tags} />
</BaseLayout>
