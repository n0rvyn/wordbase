---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagDetailBody from '../../components/page-bodies/TagDetailBody.astro';
import { getTags, getPosts, type Tag } from '../../lib/api';
import { decodeEntities } from '../../lib/home';

export async function getStaticPaths() {
  const tags = await getTags();
  return tags.map((tag: Tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

interface Props {
  tag: Tag;
}

const { tag } = Astro.props;
const { data: posts } = await getPosts({ status: 'published', tag: tag.slug, limit: 10000 });
const sorted = [...posts].sort((a, b) => (b.publishedAt ?? 0) - (a.publishedAt ?? 0));
const tagName = decodeEntities(tag.name);
---

<BaseLayout title={tagName} hasEnTwin>
  <TagDetailBody locale="zh" tagName={tagName} posts={sorted} />
</BaseLayout>
