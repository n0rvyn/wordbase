---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppDetailBody from '../../components/page-bodies/AppDetailBody.astro';
import { getApps, stripMarkdown, type App } from '../../lib/api';
import { buildSoftwareApplicationLd, buildBreadcrumbLd } from '../../lib/jsonld.js';

export async function getStaticPaths() {
  const { data: apps } = await getApps({ status: 'published', limit: 10000 });
  return apps.map((app: App) => ({
    params: { slug: app.slug },
    props: {
      app,
      moreApps: apps.filter((a: App) => a.slug !== app.slug),
    },
  }));
}

const { app, moreApps } = Astro.props as { app: App; moreApps: App[] };

// Per-app meta description: prefer the short tagline, else a trimmed excerpt of
// the App Store description, else the subtitle. Empty → BaseLayout site default.
const metaDescription =
  app.tagline ||
  (app.description ? stripMarkdown(app.description, 155) : '') ||
  app.subtitle ||
  undefined;

const origin = Astro.site!.href.replace(/\/$/, '');
const jsonLd = [
  buildSoftwareApplicationLd(app, origin),
  buildBreadcrumbLd([
    { name: 'Apps', url: `${origin}/apps` },
    { name: app.name, url: `${origin}/apps/${app.slug}` },
  ]),
];
---

<BaseLayout title={app.name} description={metaDescription} ogImage={app.icon ?? undefined} twitterCard="summary" jsonLd={jsonLd} hasEnTwin>
  <AppDetailBody locale="zh" app={app} moreApps={moreApps} />
</BaseLayout>
