---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppsIndexBody from '../../components/page-bodies/AppsIndexBody.astro';
import { getApps, type App } from '../../lib/api';
import { selectFeaturedApp, restApps } from '../../lib/home';
import { t } from '../../lib/i18n.js';

const { data: apps } = await getApps({ status: 'published' });
const featuredApp = selectFeaturedApp(apps);
const ordered: App[] = featuredApp ? [featuredApp, ...restApps(apps, featuredApp)] : [...apps];
---

<BaseLayout title="Apps" titleEn={t('title.apps').en} hasEnTwin description="我做的小而克制的应用。">
  <AppsIndexBody locale="zh" apps={ordered} />
</BaseLayout>
