---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import CommentSection from '../../components/CommentSection.astro';
import { getPosts, getCategories, formatDate, estimateReadTime, stripMarkdown, type Post, getSiteIdentity } from '../../lib/api';
import { formatMonoDate } from '../../lib/home';
import { injectHeadingIds, selectAdjacent } from '../../lib/article';
import { buildBlogPostingLd, buildBreadcrumbLd } from '../../lib/jsonld.js';
import { marked } from 'marked';
import '../../styles/prose.css';

export async function getStaticPaths() {
  const { data: posts } = await getPosts({ status: 'published', limit: 10000 });
  const sorted = [...posts].sort((a, b) => (b.publishedAt ?? 0) - (a.publishedAt ?? 0));
  const orderedSlugs = sorted.map((p: Post) => p.slug);
  const slugTitle: Record<string, string> = {};
  sorted.forEach((p: Post) => { slugTitle[p.slug] = p.title; });

  // Build per-post first-category map
  const allCats = await getCategories();
  const postFirstCat: Record<string, string> = {};
  for (const cat of allCats) {
    const { data: catPosts } = await getPosts({ status: 'published', category: cat.slug, limit: 10000 });
    for (const p of catPosts) {
      if (!postFirstCat[p.id]) {
        postFirstCat[p.id] = cat.name;
      }
    }
  }

  return sorted.map((post: Post) => ({
    params: { slug: post.slug },
    props: { post, orderedSlugs, slugTitle, postFirstCat },
  }));
}

const { post, orderedSlugs, slugTitle, postFirstCat } = Astro.props as {
  post: Post;
  orderedSlugs: string[];
  slugTitle: Record<string, string>;
  postFirstCat: Record<string, string>;
};
const meta = post.meta ? JSON.parse(post.meta) : {};
const description = post.excerpt || meta.description || stripMarkdown(post.content, 160);
const readTime = estimateReadTime(post.content);
const { html, toc } = injectHeadingIds(marked.parse(post.content) as string);
const { newer, older } = selectAdjacent(orderedSlugs, post.slug);
const firstCat = postFirstCat[post.id] || '';
const origin = Astro.site!.href.replace(/\/$/, '');
const id = await getSiteIdentity();
const jsonLd = [
  buildBlogPostingLd(post, origin, id.author),
  buildBreadcrumbLd([
    { name: 'Writing', url: `${origin}/writing` },
    { name: post.title, url: `${origin}/posts/${post.slug}` },
  ]),
];
const article = {
  publishedTime: post.publishedAt ?? undefined,
  modifiedTime: post.updatedAt,
  author: id.author,
  section: firstCat || undefined,
  tags: undefined,
};
---

<BaseLayout title={post.title} description={description} ogImage={post.coverImage || undefined} ogType="article" article={article} jsonLd={jsonLd}>
  <!-- Progress bar (owned by this page, fixed at top) -->
  <div class="progress" id="progress"></div>

  <div class="art-wrap">
    <div class="art-grid">
      <!-- Left rail -->
      <aside class="rail">
        <div class="meta">
          {post.publishedAt && (
            <div class="m">
              <span class="k">发表于</span>
              <span class="v mono">{formatMonoDate(post.publishedAt)}</span>
            </div>
          )}
          {firstCat && (
            <div class="m">
              <span class="k">分类</span>
              <span class="v">{firstCat}</span>
            </div>
          )}
          <div class="m">
            <span class="k">阅读时长</span>
            <span class="v">约 {readTime} 分钟</span>
          </div>
        </div>

        {toc.length > 0 && (
          <>
            <div class="rail-div"></div>
            <nav class="toc">
              <h5>目录</h5>
              {toc.map((t, i) => (
                <a
                  href={`#${t.id}`}
                  class:list={[{ active: i === 0 }]}
                  style={t.level === 3 ? 'padding-left:26px' : ''}
                >{t.text}</a>
              ))}
            </nav>
          </>
        )}

        <div class="rail-div"></div>
        <ShareButtons title={post.title} url={new URL(`/posts/${post.slug}`, Astro.site).href} />
      </aside>

      <!-- Article body -->
      <article class="reading">
        {firstCat && <div class="cat">{firstCat}</div>}
        <h1>{post.title}</h1>
        {description && <p class="dek">{description}</p>}
        <div class="byline">
          <div class="av">N</div>
          <div class="bm">
            <b>norvyn</b> · {post.publishedAt ? formatDate(post.publishedAt) : ''}
          </div>
        </div>

        <div class="prose" set:html={html} />
        <div class="endmark">◆</div>

        <div class="author-card">
          <div class="av">N</div>
          <div>
            <div class="an">norvyn</div>
            <p>独立 iOS 开发者，写字的人。在一座有海的城市，慢慢地做一些小而确定的东西。</p>
          </div>
        </div>

        {(older || newer) && (
          <nav class="pn-nav">
            {older ? (
              <a class="pn prev" href={`/posts/${older}`}>
                <div class="pl">← 上一篇</div>
                <div class="pt">{slugTitle[older] || ''}</div>
              </a>
            ) : <div class="pn prev empty"></div>}
            {newer ? (
              <a class="pn next" href={`/posts/${newer}`}>
                <div class="pl">下一篇 →</div>
                <div class="pt">{slugTitle[newer] || ''}</div>
              </a>
            ) : <div class="pn next empty"></div>}
          </nav>
        )}
      </article>
    </div>
  </div>

  <!-- Comments below the grid -->
  <div class="comments-wrap">
    <CommentSection postId={post.id} />
  </div>
</BaseLayout>

<!-- Scoped styles: layout + rail + reading elements -->
<style>
  .progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    z-index: 60;
    transition: width 0.1s linear;
  }

  .art-wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    /* Gut zeroed so the rail bleeds to the band edge, matching the
       home spine (.hero/.sec also zero the inline gut). main supplies
       the gut below the band width so mobile prose stays gutter'd. */
    padding-inline: 0;
  }

  .art-grid {
    display: grid;
    grid-template-columns: clamp(150px, 18vw, 236px) minmax(0, var(--measure));
    gap: var(--col-gap);
    padding: clamp(40px, 6vw, 72px) 0 60px;
  }

  /* Rail */
  .rail {
    position: sticky;
    top: 90px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .rail .meta {
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  .rail .m {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .rail .k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .rail .v {
    font-size: 14px;
    font-weight: 600;
  }

  .rail .mono {
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
  }

  .rail-div {
    height: 1px;
    background: var(--line);
  }

  /* TOC */
  .toc h5 {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 12px;
    font-weight: 500;
  }

  .toc a {
    display: block;
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink-3);
    padding: 7px 0 7px 13px;
    border-left: 2px solid var(--line);
    margin-left: -1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .toc a:hover {
    color: var(--ink-2);
  }

  .toc a.active {
    color: var(--ink);
    border-color: var(--accent);
  }

  /* Reading area */
  .reading .cat {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }

  .reading h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(30px, 4.4vw, 52px);
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin: 0 0 18px;
    /* No text-wrap:balance — balance shortens line 1 (~399px) so the title
       never reaches the body's right edge; normal wrap fills the measure. */
  }

  .reading .dek {
    font-family: var(--font-read);
    font-size: clamp(17px, 1.9vw, 21px);
    line-height: 1.6;
    color: var(--ink-2);
    margin: 0 0 26px;
    max-width: none;
  }

  /* Override @tailwindcss/typography's .prose 65ch cap so the body fills the
     reading column (var(--measure)) and aligns with h1 + .dek. Scoped to
     .reading so companion pages ([slug].astro) keep Tailwind's default. */
  .reading .prose {
    max-width: none;
  }

  .byline {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 8px;
  }

  .byline .av {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface-2);
    border: 1px solid var(--line);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 15px;
    color: var(--ink-3);
  }

  .byline .bm {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-3);
    letter-spacing: 0.03em;
  }

  .byline .bm b {
    color: var(--ink);
    font-weight: 600;
  }

  .endmark {
    margin: 2.2em 0 0;
    color: var(--accent);
    font-size: 22px;
    line-height: 1;
  }

  /* Author card */
  .author-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid var(--line);
  }

  .author-card .av {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--surface-2);
    border: 1px solid var(--line);
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    color: var(--ink-3);
  }

  .author-card .an {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.01em;
  }

  .author-card p {
    margin: 5px 0 0;
    font-family: var(--font-read);
    font-size: 14.5px;
    color: var(--ink-2);
    line-height: 1.6;
    max-width: 48ch;
  }

  /* Prev/next navigation */
  .pn-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 48px;
  }

  .pn {
    padding: 20px 22px;
    border: 1px solid var(--line);
    border-radius: 16px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .pn:hover {
    border-color: var(--line-2);
    transform: translateY(-2px);
  }

  .pn.empty {
    border-color: transparent;
    pointer-events: none;
  }

  .pn .pl {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 8px;
  }

  .pn .pt {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    line-height: 1.3;
    transition: color 0.2s;
  }

  .pn:hover .pt {
    color: var(--accent);
  }

  .pn.next {
    text-align: right;
  }

  /* Comments container */
  .comments-wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    /* gut supplied by main; keep 0 here so it aligns with the article body */
    padding-inline: 0;
    padding-bottom: 60px;
  }

  /* Responsive */
  @media (max-width: 880px) {
    .art-grid {
      /* minmax(0,1fr) (not bare 1fr = minmax(auto,1fr)) so a wide <pre>
         code block scrolls inside its own box instead of blowing the
         column past the viewport. */
      grid-template-columns: minmax(0, 1fr);
      gap: 8px;
    }

    .rail {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 18px 28px;
      margin-bottom: 18px;
    }

    .toc,
    .rail-div {
      display: none;
    }

    .pn-nav {
      grid-template-columns: 1fr;
    }

    .pn.next {
      text-align: left;
    }
  }
</style>

<!-- Prose typography loaded via src/styles/prose.css (imported in frontmatter) -->

<script>
  // Progress bar
  const bar = document.getElementById('progress') as HTMLDivElement | null;
  function updateProgress() {
    if (!bar) return;
    const h = document.documentElement;
    const sc = h.scrollHeight - h.clientHeight;
    bar.style.width = (sc > 0 ? (h.scrollTop / sc * 100) : 0) + '%';
  }
  addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // TOC scroll-spy
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc a'));
  const secs = tocLinks.map(a => document.getElementById(a.getAttribute('href')!.slice(1)));
  function spy() {
    const y = scrollY + 120;
    let idx = 0;
    for (let i = 0; i < secs.length; i++) {
      if (secs[i] && (secs[i] as HTMLElement).offsetTop <= y) idx = i;
    }
    tocLinks.forEach((a, i) => a.classList.toggle('active', i === idx));
  }
  addEventListener('scroll', spy, { passive: true });
  spy();

  // Smooth-scroll on TOC click
  tocLinks.forEach(a => {
    a.addEventListener('click', e => {
      e.preventDefault();
      const t = document.getElementById(a.getAttribute('href')!.slice(1));
      if (t) window.scrollTo({ top: (t as HTMLElement).offsetTop - 92, behavior: 'smooth' });
    });
  });
</script>
