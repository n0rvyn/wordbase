---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getPodcasts,
  getEpisodes,
  stripMarkdown,
  type Episode,
} from '../../lib/api';
import { selectFeaturedEpisode, decodeEntities } from '../../lib/home';
import { selectShow, sortEpisodes, episodeMeta } from '../../lib/podcast';
import { FEEDBACK_CHIPS } from '../../lib/feedback';
import { buildPodcastLd } from '../../lib/jsonld.js';
import T from '../../components/T.astro';
import { t } from '../../lib/i18n.js';

const apiUrl = (import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4100').replace(/\/$/, '');

const { data: podcasts } = await getPodcasts({ status: 'published' });
const podcast = selectShow(podcasts);

let episodes: Episode[] = [];
if (podcast) {
  episodes = (await getEpisodes(podcast.slug, { status: 'published', limit: 10000 })).data;
}

const featuredEp = selectFeaturedEpisode(episodes);
const archive = sortEpisodes(episodes).filter(e => e.id !== featuredEp?.id);

const showTitle = podcast ? decodeEntities(podcast.title) : '播客';
const feedHref = podcast ? `/api/podcasts/${podcast.slug}/feed.xml` : null;
const host = podcast?.author ?? podcast?.ownerName ?? null;
const showCover = podcast?.coverImage || featuredEp?.coverImage || null;

// Grey 2-line blurb for an episode row — short summary only (full transcript
// lives in showNotes / content:encoded, far too long for the list). Returns
// '' when absent so the markup can skip rendering an empty line.
const epBlurb = (ep: Episode): string => (ep.summary ? stripMarkdown(ep.summary, 180) : '');

const origin = Astro.site!.href.replace(/\/$/, '');
const jsonLd = podcast ? [buildPodcastLd(podcast, episodes, origin)] : [];
---

<BaseLayout
  title={podcast ? showTitle : '播客'}
  titleEn={t('title.podcast').en}
  description={podcast?.description ? stripMarkdown(podcast.description, 120) : '一档慢节奏的播客。'}
  ogImage="/og-podcast.png"
  jsonLd={jsonLd}
  feeds={feedHref ? [{ title: `${showTitle} · Podcast`, href: feedHref }] : []}
>

<!-- 00 HERO — show header (cover + identity) -->
<header class="sec wrap" style="border-top:none;padding-top:clamp(44px,6vw,80px)">
  <div class="row2">
    <div class="spine">
      <span class="no">00</span>
      <span class="lab">Podcast</span>
      {podcast && <span class="note"><T k="podcast.spine.note" /></span>}
      {!podcast && <span class="note"><T k="podcast.fallbackDesc" /></span>}
    </div>
    <div class="show-head">
      <div class="eyebrow">
        <span>Podcast{host && <Fragment> · <T k="podcast.eyebrowHost" /> {host}</Fragment>}</span>
        {(podcast?.appleUrl || podcast?.spotifyUrl) && (
          <span class="eyebrow-listen">
            {podcast?.appleUrl && (
              <a class="ch-mini" href={podcast.appleUrl} target="_blank" rel="noopener noreferrer" data-i18n-aria="podcast.listenApple" aria-label="在 Apple Podcasts 收听">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M5.34 0A5.328 5.328 0 000 5.34v13.32A5.328 5.328 0 005.34 24h13.32A5.328 5.328 0 0024 18.66V5.34A5.328 5.328 0 0018.66 0zm6.525 2.568c2.336 0 4.448.902 6.056 2.587 1.224 1.272 1.912 2.619 2.264 4.392.12.59.12 2.2.007 2.864a8.506 8.506 0 01-3.24 5.296c-.608.46-2.096 1.261-2.336 1.261-.088 0-.096-.091-.056-.46.072-.592.144-.715.48-.856.536-.224 1.448-.874 2.008-1.435a7.644 7.644 0 002.008-3.536c.208-.824.184-2.656-.048-3.504-.728-2.696-2.928-4.792-5.624-5.352-.784-.16-2.208-.16-3 0-2.728.56-4.984 2.76-5.672 5.528-.184.752-.184 2.584 0 3.336.456 1.832 1.64 3.512 3.192 4.512.304.2.672.408.824.472.336.144.408.264.472.856.04.36.03.464-.056.464-.056 0-.464-.176-.896-.384l-.04-.03c-2.472-1.216-4.056-3.274-4.632-6.012-.144-.706-.168-2.392-.03-3.04.36-1.74 1.048-3.1 2.192-4.304 1.648-1.737 3.768-2.656 6.128-2.656zm.134 2.81c.409.004.803.04 1.106.106 2.784.62 4.76 3.408 4.376 6.174-.152 1.114-.536 2.03-1.216 2.88-.336.43-1.152 1.15-1.296 1.15-.023 0-.048-.272-.048-.603v-.605l.416-.496c1.568-1.878 1.456-4.502-.256-6.224-.664-.67-1.432-1.064-2.424-1.246-.64-.118-.776-.118-1.448-.008-1.02.167-1.81.562-2.512 1.256-1.72 1.704-1.832 4.342-.264 6.222l.413.496v.608c0 .336-.027.608-.06.608-.03 0-.264-.16-.512-.36l-.034-.011c-.832-.664-1.568-1.842-1.872-2.997-.184-.698-.184-2.024.008-2.72.504-1.878 1.888-3.335 3.808-4.019.41-.145 1.133-.22 1.814-.211zm-.13 2.99c.31 0 .62.06.844.178.488.253.888.745 1.04 1.259.464 1.578-1.208 2.96-2.72 2.254h-.015c-.712-.331-1.096-.956-1.104-1.77 0-.733.408-1.371 1.112-1.745.224-.117.534-.176.844-.176zm-.011 4.728c.988-.004 1.706.349 1.97.97.198.464.124 1.932-.218 4.302-.232 1.656-.36 2.074-.68 2.356-.44.39-1.064.498-1.656.288h-.003c-.716-.257-.87-.605-1.164-2.644-.341-2.37-.416-3.838-.218-4.302.262-.616.974-.966 1.97-.97z"/></svg>
                <span>Apple</span>
              </a>
            )}
            {podcast?.spotifyUrl && (
              <a class="ch-mini" href={podcast.spotifyUrl} target="_blank" rel="noopener noreferrer" data-i18n-aria="podcast.listenSpotify" aria-label="在 Spotify 收听">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.42 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                <span>Spotify</span>
              </a>
            )}
          </span>
        )}
      </div>
      <div class="show-body">
        <div class="show-id">
          <div class="show-cover">
            {showCover
              ? <img src={showCover} alt={showTitle} width="132" height="132" loading="eager" />
              : <span>{showTitle.charAt(0)}</span>
            }
          </div>
          {feedHref && (
            <div class="subscribe">
              <a class="btn btn-1" href={feedHref}><T k="podcast.subscribe" /> ↗</a>
            </div>
          )}
        </div>
        <div class="show-meta">
          <h1 class="show-title">{showTitle}</h1>
          <p class="lede">
            {podcast?.description ? stripMarkdown(podcast.description, podcast.description.length) : <T k="podcast.fallbackDesc" />}
          </p>
        </div>
      </div>
    </div>
  </div>
</header>

{!podcast && (
  <!-- Empty path A: no published podcast -->
  <section class="sec wrap">
    <div class="empty"><T k="podcast.emptyShow" /></div>
  </section>
)}

{podcast && !featuredEp && (
  <!-- Empty path B: podcast exists but no episodes -->
  <section class="sec wrap">
    <div class="row2">
      <div class="spine">
        <span class="no">01</span>
        <span class="lab">Latest</span>
        <span class="note"><T k="podcast.latest.note" /></span>
      </div>
      <div class="empty"><T k="podcast.emptyEps" /></div>
    </div>
  </section>
)}

{podcast && featuredEp && (
  <!-- 01 LATEST — same row structure as the archive, just emphasized -->
  <section class="sec wrap">
    <div class="row2">
      <div class="spine">
        <span class="no">01</span>
        <span class="lab">Latest</span>
        <span class="note"><T k="podcast.latest.note" /></span>
      </div>
      <div class="ep-list">
        <article class="ep-item ep-item--feature" id={`ep-${featuredEp.slug}`}>
          <span class="ep-eyebrow ep-eyebrow--accent">
            {featuredEp.episodeNumber != null ? <T zh={`EP.${featuredEp.episodeNumber} · 最新一期`} en={`EP.${featuredEp.episodeNumber} · Latest episode`} /> : <T k="podcast.latestPrefix" />}
          </span>
          <div class="ep-title-row">
            <h3 class="ep-title"><a href={`/podcast/${featuredEp.slug}`}>{featuredEp.title}</a></h3>
            <button type="button" class="ep-share" data-ep-slug={featuredEp.slug} data-i18n-title="podcast.shareEpisode" data-i18n-aria="podcast.shareEpisode" title="分享本集" aria-label="分享本集">
              <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 16V4"/><path d="m8 8 4-4 4 4"/><path d="M5 12v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6"/>
              </svg>
            </button>
          </div>
          {epBlurb(featuredEp) && <p class="ep-sum">{epBlurb(featuredEp)}</p>}
          <audio controls preload="none" src={`/api/podcasts/episodes/${encodeURIComponent(featuredEp.slug)}/download`}></audio>
          {featuredEp.transcript && (
            <div class="tx" data-slug={featuredEp.slug} data-api-url={apiUrl}>
              <button type="button" class="tx-toggle" aria-expanded="false"><T k="podcast.transcript" /><span class="tx-caret">▾</span></button>
              <div class="tx-panel" hidden>
                <div class="tx-body"></div>
              </div>
            </div>
          )}
          <div class="ep-fb" data-slug={featuredEp.slug} data-api-url={apiUrl}>
            <div class="ep-fb-chips">
              {FEEDBACK_CHIPS.map((chip) => (
                <button type="button" class="ep-fb-chip" data-category={chip.category}><T zh={chip.label} en={chip.labelEn} /></button>
              ))}
              <button type="button" class="ep-fb-say"><T k="podcast.fbSay" /></button>
            </div>
            <input class="ep-fb-note msg-hidden" type="text" maxlength="200" data-i18n-placeholder="podcast.fbPlaceholder" placeholder="一句话（可选）" />
            <p class="ep-fb-hint msg-hidden"><T k="podcast.fbHint" /></p>
            <p class="ep-fb-msg msg-hidden"></p>
            <p class="ep-fb-thanks msg-hidden"><T k="podcast.fbThanks" /></p>
          </div>
        </article>
      </div>
    </div>
  </section>
)}

{podcast && archive.length > 0 && (
  <!-- 02 ALL EPISODES -->
  <section class="sec wrap">
    <div class="row2">
      <div class="spine">
        <span class="no">02</span>
        <span class="lab"><T k="podcast.episodes.lab" /></span>
        <span class="note"><T k="podcast.episodes.note" /></span>
      </div>
      <div class="ep-list">
        {archive.map((ep: Episode) => (
          <article class="ep-item" id={`ep-${ep.slug}`}>
            <span class="ep-eyebrow">{episodeMeta(ep)}</span>
            <div class="ep-title-row">
              <h3 class="ep-title"><a href={`/podcast/${ep.slug}`}>{ep.title}</a></h3>
              <button type="button" class="ep-share" data-ep-slug={ep.slug} data-i18n-title="podcast.shareEpisode" data-i18n-aria="podcast.shareEpisode" title="分享本集" aria-label="分享本集">
                <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 16V4"/><path d="m8 8 4-4 4 4"/><path d="M5 12v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6"/>
                </svg>
              </button>
            </div>
            {epBlurb(ep) && <p class="ep-sum">{epBlurb(ep)}</p>}
            <audio controls preload="none" src={`/api/podcasts/episodes/${encodeURIComponent(ep.slug)}/download`}></audio>
            {ep.transcript && (
              <div class="tx" data-slug={ep.slug} data-api-url={apiUrl}>
                <button type="button" class="tx-toggle" aria-expanded="false"><T k="podcast.transcript" /><span class="tx-caret">▾</span></button>
                <div class="tx-panel" hidden>
                  <div class="tx-body"></div>
                </div>
              </div>
            )}
            <div class="ep-fb" data-slug={ep.slug} data-api-url={apiUrl}>
              <div class="ep-fb-chips">
                {FEEDBACK_CHIPS.map((chip) => (
                  <button type="button" class="ep-fb-chip" data-category={chip.category}><T zh={chip.label} en={chip.labelEn} /></button>
                ))}
                <button type="button" class="ep-fb-say"><T k="podcast.fbSay" /></button>
              </div>
              <input class="ep-fb-note msg-hidden" type="text" maxlength="200" data-i18n-placeholder="podcast.fbPlaceholder" placeholder="一句话（可选）" />
              <p class="ep-fb-hint msg-hidden"><T k="podcast.fbHint" /></p>
              <p class="ep-fb-msg msg-hidden"></p>
              <p class="ep-fb-thanks msg-hidden"><T k="podcast.fbThanks" /></p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

</BaseLayout>

<script>
  import { wireFeedback, wireTranscript } from '../../lib/episode-ui';

  document.querySelectorAll<HTMLElement>('.ep-fb').forEach(wireFeedback);
  document.querySelectorAll<HTMLElement>('.tx').forEach((el) => { void wireTranscript(el); });

  // Per-episode share: links to the single-episode page /podcast/<slug> (a real
  // URL, so social crawlers see per-episode OG tags — a #fragment would be
  // stripped and every share would collapse to the list page's card). Mobile
  // uses the system share sheet (target=native), desktop copies (target=copy).
  function trackShare(path: string, target: string) {
    const apiUrl = document.body.dataset.apiUrl;
    if (!apiUrl) return;
    fetch(`${apiUrl}/api/analytics/share`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ path, target }),
      keepalive: true,
    }).catch(() => {});
  }

  document.querySelectorAll<HTMLButtonElement>('.ep-share').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const slug = btn.dataset.epSlug;
      if (!slug) return;
      const path = `/podcast/${slug}`;
      const url = `${location.origin}${path}`;
      if (typeof navigator.share === 'function') {
        trackShare(path, 'native');
        navigator.share({ url }).catch(() => {});
        return;
      }
      trackShare(path, 'copy');
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        const input = document.createElement('input');
        input.value = url;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
      }
      // Icon-only feedback: swap the share glyph for a checkmark for ~1.3s.
      const svg = btn.querySelector('svg');
      if (svg) {
        const orig = svg.innerHTML;
        svg.innerHTML = '<path d="M20 6 9 17l-5-5"/>';
        btn.classList.add('copied');
        setTimeout(() => { svg.innerHTML = orig; btn.classList.remove('copied'); }, 1300);
      }
    });
  });
</script>

<style>
  /* ── Sections ─────────────────────────────────────────────────────────────── */
  .sec { padding: clamp(44px, 6vw, 84px) 0; border-top: 1px solid var(--line); }

  /* ── Eyebrow ──────────────────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono); font-size: 12.5px;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-3); margin-bottom: 22px;
    display: flex; flex-wrap: wrap; align-items: center; gap: 8px 14px;
  }
  /* Platform listen links trailing the eyebrow text — 14px logo + label.
     The label drops the eyebrow's uppercase + tracking and runs a touch
     brighter (ink-2 vs the eyebrow's ink-3), so the mixed-case "Apple/Spotify"
     stands out slightly against the all-caps meta line. Hover → accent. */
  .eyebrow-listen { display: inline-flex; align-items: center; gap: 16px; }
  .ch-mini {
    display: inline-flex; align-items: center; gap: 5px;
    color: var(--ink-2); text-transform: none; letter-spacing: 0;
    transition: color .18s;
  }
  .ch-mini svg { flex-shrink: 0; }
  .ch-mini:hover { color: var(--accent); }

  /* ── Buttons ──────────────────────────────────────────────────────────────── */
  .btn {
    font-family: var(--font-ui); font-size: 15px; font-weight: 600;
    cursor: pointer; padding: 12px 20px; border-radius: 99px;
    border: 1px solid transparent;
    transition: transform .18s var(--ease), background .2s, border-color .2s;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn-1 { background: var(--accent); color: var(--on-accent); }
  .btn-2 { background: transparent; color: var(--ink); border-color: var(--line-2); }
  .btn-2:hover { border-color: var(--ink-3); background: var(--surface-2); }

  /* ── Subscribe (RSS CTA, stacked under the cover in the show-id column) ────── */
  .subscribe { display: flex; flex-direction: column; align-items: flex-start; gap: 10px; }

  /* ── Show header (00 HERO) ────────────────────────────────────────────────── */
  /* Cover-left, identity-right (Apple show-header). To flip the cover to the
     right, change grid-template-columns to `1fr auto` and reorder is automatic
     since .show-cover comes first in source — move it after .show-meta instead. */
  /* Eyebrow is a full-width kicker on top; the cover+subscribe column and the
     identity (title + lede) column below it start at the same line, so the
     icon/RSS top-align with the title and body, not with the small eyebrow. */
  .show-body {
    display: grid; grid-template-columns: auto 1fr;
    gap: clamp(20px, 3vw, 36px); align-items: start;
  }
  /* Left column: cover + subscribe stacked, top-aligned with the identity text. */
  .show-id { display: flex; flex-direction: column; gap: 20px; align-items: flex-start; }
  .show-cover {
    width: clamp(112px, 13vw, 132px); aspect-ratio: 1;
    border-radius: var(--r-lg); flex-shrink: 0; overflow: hidden;
    background: radial-gradient(120% 120% at 20% 0%, color-mix(in srgb, var(--accent) 50%, #15151a), #0e0e14);
    display: grid; place-items: center; box-shadow: var(--shadow);
  }
  .show-cover img { width: 100%; height: 100%; object-fit: cover; }
  .show-cover span {
    font-family: var(--font-display); font-weight: 700;
    font-size: 38px; color: #fff; letter-spacing: -.03em;
  }
  .show-meta h1 {
    margin: 0;
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(28px, 3.4vw, 40px); line-height: 1.12; letter-spacing: -.02em;
  }

  /* ── Episode rows (01 Latest + 02 Episodes share this) ────────────────────── */
  .ep-list { display: flex; flex-direction: column; }
  .ep-item {
    display: flex; flex-direction: column; align-items: flex-start;
    gap: 10px; padding: 26px 0; border-top: 1px solid var(--line);
  }
  .ep-item:first-child { border-top: none; padding-top: 2px; }
  .ep-eyebrow {
    font-family: var(--font-mono); font-size: 11.5px;
    letter-spacing: .1em; text-transform: uppercase; color: var(--ink-3);
  }
  .ep-eyebrow--accent { color: var(--accent); }
  .ep-title {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(18px, 1.7vw, 21px); letter-spacing: -.02em;
    line-height: 1.3; margin: 0;
  }
  /* Title links to the single-episode page; reads as plain text until hover. */
  .ep-title a { color: inherit; text-decoration: none; transition: color .2s; }
  .ep-title a:hover { color: var(--accent); }
  /* The featured (latest) episode reads larger than the archive rows. */
  .ep-item--feature .ep-title { font-size: clamp(20px, 2.3vw, 26px); }
  .ep-sum {
    font-family: var(--font-read); font-size: 15px; line-height: 1.6;
    color: var(--ink-2); max-width: 64ch; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  audio { width: 100%; max-width: 480px; margin-top: 6px; }

  /* ── Transcript (per-episode transcript toggle + scrolling panel) ──────────
     Container, toggle and panel are build-time elements — scoped styles apply.
     The .tx-line <p> rows are runtime-injected (innerHTML/createElement) and
     carry no data-astro-cid, so they must be styled via :global(...) below. */
  .tx { width: 100%; max-width: 480px; margin-top: 10px; }
  .tx-toggle {
    font-family: var(--font-ui); font-size: 13px; color: var(--ink-3);
    background: none; border: none; padding: 4px 0; cursor: pointer;
    display: inline-flex; align-items: center; gap: 6px;
  }
  .tx-toggle:hover { color: var(--ink); }
  .ep-title-row {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 14px;
  }
  .ep-share {
    flex-shrink: 0; margin-top: 2px;
    color: var(--ink-4); background: none; border: none; padding: 2px; cursor: pointer;
    display: inline-flex; line-height: 0; transition: color 0.2s;
  }
  .ep-share:hover, .ep-share.copied { color: var(--accent); }
  .tx-caret { transition: transform .2s var(--ease); font-size: 10px; }
  .tx-toggle[aria-expanded="true"] .tx-caret { transform: rotate(180deg); }
  .tx-panel {
    margin-top: 8px; max-height: 320px; overflow-y: auto;
    border-left: 2px solid var(--line); padding-left: 14px;
  }
  /* No scroll-behavior: smooth — a smooth scroll fires multiple scroll events
     that the 250ms time window can't fully swallow, so we'd lose the ability
     to distinguish program vs. user scrolling. Program scroll is an instant
     scrollTop assignment (single event); the visual gap is acceptable. */
  /* Runtime-injected rows (innerHTML) — :global because Astro's scoped
     data-astro-cid attribute is absent on elements created in the client. */
  :global(.tx-line) {
    font-family: var(--font-read); font-size: 14.5px; line-height: 1.7;
    color: var(--ink-3); margin: 0 0 10px; padding: 2px 6px; border-radius: 6px;
