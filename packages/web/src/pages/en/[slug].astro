---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompanionBody from '../../components/page-bodies/CompanionBody.astro';
import { getPages, stripMarkdown, type Page } from '../../lib/api';
import { localizePage } from '../../lib/localize';
import { marked } from 'marked';

export async function getStaticPaths() {
  const pages = await getPages();
  return pages
    .filter((p: Page) => p.status === 'published')
    .map((p: Page) => ({
      params: { slug: p.slug },
      props: { page: p },
    }));
}

interface Props {
  page: Page;
}

const { page } = Astro.props;
const localized = await localizePage(page, 'en');
const htmlContent = marked.parse(localized.content) as string;
const metaDescription = stripMarkdown(localized.content, 155) || undefined;
---

<BaseLayout title={localized.title} description={metaDescription} locale="en">
  <CompanionBody title={localized.title} htmlContent={htmlContent} />
</BaseLayout>
