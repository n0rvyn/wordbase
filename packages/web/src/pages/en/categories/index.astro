---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CategoriesIndexBody from '../../../components/page-bodies/CategoriesIndexBody.astro';
import { getCategories, getPosts } from '../../../lib/api';

const categories = await getCategories();
const catCounts = new Map<string, number>();
for (const cat of categories) {
  const { data } = await getPosts({ status: 'published', category: cat.slug, limit: 10000 });
  catCounts.set(cat.slug, data.length);
}
---

<BaseLayout title="Categories" locale="en" description="All writing categories.">
  <CategoriesIndexBody locale="en" categories={categories} catCounts={catCounts} />
</BaseLayout>
