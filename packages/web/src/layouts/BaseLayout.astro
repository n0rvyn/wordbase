---
import '../styles/tokens.css';
import { buildWebSiteLd, buildOrganizationLd } from '../lib/jsonld.js';
import { getSiteIdentity } from '../lib/api';
import T from '../components/T.astro';

interface Props {
  title: string;
  /** English title for client-side <title> swap when language is en.
   *  Static <title> still renders Chinese (crawler/no-JS default);
   *  the bundled script overwrites document.title at runtime. Leave
   *  undefined for API-derived titles (posts, apps, podcast, tag/category
   *  detail pages) where the title IS the content and stays Chinese. */
  titleEn?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  article?: { publishedTime?: number; modifiedTime?: number; author?: string; section?: string; tags?: string[] };
  jsonLd?: object[];
  // Extra <link rel="alternate"> feeds beyond the site blog feed (e.g. the
  // podcast page injects its show feed, whose slug only the page knows).
  feeds?: { title: string; href: string }[];
}

// 保留现有默认串逐字不变，避免回归既有页面 meta。
const { title, titleEn, description = 'A personal blog powered by Wordbase', ogImage, ogType = 'website', article, jsonLd = [], feeds = [] } = Astro.props;
const id = await getSiteIdentity();
const siteTitle = id.name;
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
// Mirror the same join rule for the English title so 'Apps — norvyn' style
// canonical titles are preserved on the EN tab label. If the caller didn't
// pass a titleEn, fullTitleEn stays empty and the bundled script leaves
// the (Chinese) document.title untouched.
const fullTitleEn = titleEn ? (titleEn === siteTitle ? titleEn : `${titleEn} — ${siteTitle}`) : '';
const apiUrl = (import.meta.env.PUBLIC_SITE_URL || 'http://localhost:4100').replace(/\/$/, '');
const currentPath = Astro.url.pathname;
const ogImageUrl = new URL(ogImage ?? '/og-image.png', Astro.site).href;
const canonicalUrl = new URL(currentPath, Astro.site).href;
const ldOrigin = Astro.site!.href.replace(/\/$/, '');
const isoMeta = (ts: number | undefined) => (ts ? new Date(ts * 1000).toISOString() : undefined);

const navItems = [
  { href: '/apps',     label: 'Apps',    isActive: currentPath.startsWith('/apps') },
  { href: '/writing',  label: 'Writing', isActive: currentPath.startsWith('/writing') },
  { href: '/podcast',  label: 'Podcast', isActive: currentPath.startsWith('/podcast') },
];
---

<html lang="zh-CN" data-theme="light" data-title-en={fullTitleEn || undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteTitle} — 文章`} href="/rss.xml" />
    {feeds.map((f) => (
      <link rel="alternate" type="application/rss+xml" title={f.title} href={f.href} />
    ))}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    {ogType === 'article' && article && (
      <>
        {isoMeta(article.publishedTime) && <meta property="article:published_time" content={isoMeta(article.publishedTime)} />}
        {isoMeta(article.modifiedTime) && <meta property="article:modified_time" content={isoMeta(article.modifiedTime)} />}
        {article.author && <meta property="article:author" content={article.author} />}
        {article.section && <meta property="article:section" content={article.section} />}
        {article.tags?.map((t) => (
          <meta property="article:tag" content={t} />
        ))}
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {[buildWebSiteLd(ldOrigin, id), buildOrganizationLd(ldOrigin, id), ...jsonLd].map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj).replaceAll('<', String.fromCharCode(92)+'u003c')} />
    ))}
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500&family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap" rel="stylesheet" />
    <!-- FOUC-prevention bootstrap: read localStorage['norvyn-v2'] before paint.
         is:inline + in <head> => runs synchronously before <body> paints (no FOUC).
         Cannot import src/lib/theme.ts here; this hand-mirrors readPrefs +
         resolveTheme/resolveAccent. Keep in sync with that module.
         Also resolves the active UI language — mirrors lib/i18n.ts detectLang()
         three-level guard exactly: stored 'zh'/'en' wins, else falsy
         navigator.language → 'zh' default BEFORE the startsWith('zh') check,
         else prefix test. -->
    <script is:inline>
      (function() {
        var LS = 'norvyn-v2';
        var DEFAULT_THEME = 'light';
        var DEFAULT_ACCENT = '#3457B6';
        try {
          var stored = JSON.parse(localStorage.getItem(LS) || '{}');
          var theme = stored.theme || DEFAULT_THEME;
          var accent = stored.accent || DEFAULT_ACCENT;
          var lang = (stored.lang === 'zh' || stored.lang === 'en') ? stored.lang : (!navigator.language ? 'zh' : (navigator.language.toLowerCase().indexOf('zh') === 0 ? 'zh' : 'en'));
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.setProperty('--accent', accent);
          document.documentElement.setAttribute('data-lang', lang);
          document.documentElement.setAttribute('lang', lang === 'en' ? 'en' : 'zh-CN');
        } catch(e) {
          document.documentElement.setAttribute('data-theme', DEFAULT_THEME);
          document.documentElement.setAttribute('data-lang', 'zh');
          document.documentElement.setAttribute('lang', 'zh-CN');
        }
      })();
    </script>
  </head>
  <body data-api-url={apiUrl}>
    <nav class="nav" id="nav">
      <div class="wrap nav-in">
        <a class="brand" href="/">
          <span>{siteTitle}</span><span class="dot"></span>
        </a>
        <div class="nav-r">
          <div class="nav-links" id="navLinks">
            {navItems.map(item => (
              <a href={item.href} class:list={[{ active: item.isActive }]}>{item.label}</a>
            ))}
          </div>
          <button class="icon-btn" id="themeBtn" data-i18n-aria="common.themeToggle" aria-label="切换主题">
            <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
            <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.4M12 19.1v2.4M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.6 19.4l1.7-1.7M17.7 6.3l1.7-1.7"/></svg>
          </button>
          <button class="icon-btn lang-btn" id="langBtn" data-i18n-aria="common.langToggle" aria-label="切换语言">
            <span class="lang-zh">中</span><span class="lang-en">EN</span>
          </button>
          <button class="icon-btn nav-burger" id="navBurger" aria-expanded="false" aria-controls="navLinks" data-i18n-aria="common.menu" aria-label="菜单">
            <svg class="burger-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
            <svg class="burger-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <div class="wrap foot">
        <div class="foot-l">
          <div class="brand"><span>{siteTitle}</span><span class="dot"></span></div>
          <p><T k="foot.tagline" /></p>
        </div>
        <div class="foot-cols">
          <div class="foot-col">
            <h4><T k="foot.colNav" /></h4>
            <a href="/apps"><T k="foot.linkApps" /></a>
            <a href="/writing"><T k="foot.linkWriting" /></a>
            <a href="/podcast"><T k="foot.linkPodcast" /></a>
            <a href="/about"><T k="foot.linkAbout" /></a>
          </div>
          <div class="foot-col">
            <h4><T k="foot.colMore" /></h4>
            <a href="/categories"><T k="foot.linkCategories" /></a>
            <a href="/tags"><T k="foot.linkTags" /></a>
            <a href="/archives"><T k="foot.linkArchives" /></a>
          </div>
          <div class="foot-col">
            <h4><T k="foot.colElsewhere" /></h4>
            <a href={`mailto:${id.email}`}>Email</a>
            <a href={id.github} target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </div>
        <div class="foot-bot">
          <span>© {new Date().getFullYear()} {siteTitle}</span>
          <span><T k="foot.builtWith" /></span>
        </div>
      </div>
    </footer>

    <!-- Theme + language toggle + nav scroll border. Bundled module so it can
         reuse the tested persistence helpers in src/lib/theme.ts and the
         i18n helpers in src/lib/i18n.ts (single source of truth). -->
    <script>
      import {
        THEME_LS_KEY,
        DEFAULT_THEME,
        readPrefs,
        mergePrefs,
        nextTheme,
        resolveAccent,
      } from '../lib/theme';
      import {
        applyAttrI18n,
        nextLang,
        type Lang,
      } from '../lib/i18n';

      function applyToDom(theme: string, accent: string) {
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.setProperty('--accent', accent);
      }

      // Capture the server-rendered <title> once (the Chinese original) before
      // any swap, so toggling back to ZH can restore it.
      const ssrTitle = document.title;

      function applyLangToDom(lang: Lang) {
        document.documentElement.setAttribute('data-lang', lang);
        document.documentElement.setAttribute('lang', lang === 'en' ? 'en' : 'zh-CN');
        // <title> head-swap (two-way): pages with a static title supply
        // data-title-en. Swap to English in EN, restore the captured Chinese
        // SSR title in ZH — a one-way overwrite would leave the tab stuck in
        // English after EN→ZH. Pages without titleEn (API-derived titles:
        // posts, apps, podcast, tag/category details) have en === undefined,
        // so document.title is always set back to ssrTitle (their Chinese).
        const en = document.documentElement.dataset.titleEn;
        document.title = (en && lang === 'en') ? en : ssrTitle;
      }

      // Nav scroll border
      const nav = document.getElementById('nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('scrolled', window.scrollY > 10);
        }, { passive: true });
      }

      // Apply i18n attribute translation for the active language on load
      // (the head bootstrap already set data-lang — we honour it). If a user
      // opens DevTools and rewrites data-lang the attributes stay stale; this
      // hook is the only one responsible for keeping aria/placeholder/title
      // in sync with the active language.
      const initialLang = (document.documentElement.getAttribute('data-lang') as Lang) || 'zh';
      applyAttrI18n(document, initialLang);
      // Head <title> swap on first load too (the head bootstrap can't run
      // applyLangToDom because it lives is:inline and must not import).
      applyLangToDom(initialLang);

      // Theme toggle button
      const btn = document.getElementById('themeBtn');
      if (btn) {
        btn.addEventListener('click', () => {
          const prefs = readPrefs(localStorage.getItem(THEME_LS_KEY));
          const current = document.documentElement.getAttribute('data-theme') || DEFAULT_THEME;
          const theme = nextTheme(current);
          const accent = resolveAccent(prefs);
          localStorage.setItem(THEME_LS_KEY, JSON.stringify(mergePrefs(prefs, { theme, accent })));
          applyToDom(theme, accent);
        });
      }

      // Language toggle button. Persists into the same norvyn-v2 blob as
      // theme/accent (the theme prefs read/write interface already carries
      // `lang` through mergePrefs; no extra localStorage key).
      const langBtn = document.getElementById('langBtn');
      if (langBtn) {
        langBtn.addEventListener('click', () => {
          const prefs = readPrefs(localStorage.getItem(THEME_LS_KEY));
          const current = (document.documentElement.getAttribute('data-lang') as Lang) || 'zh';
          const lang = nextLang(current);
          localStorage.setItem(THEME_LS_KEY, JSON.stringify(mergePrefs(prefs, { lang })));
          applyLangToDom(lang);
          applyAttrI18n(document, lang);
        });
      }

      // Mobile hamburger: toggles the nav-links dropdown (only visible ≤640px).
      // Closes on link tap, outside click, or Escape.
      const burger = document.getElementById('navBurger');
      if (nav && burger) {
        const setMenu = (open: boolean) => {
          nav.classList.toggle('menu-open', open);
          burger.setAttribute('aria-expanded', String(open));
        };
        burger.addEventListener('click', (e) => {
          e.stopPropagation();
          setMenu(!nav.classList.contains('menu-open'));
        });
        document.getElementById('navLinks')?.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('a')) setMenu(false);
        });
        document.addEventListener('click', (e) => {
          if (nav.classList.contains('menu-open') && !nav.contains(e.target as Node)) setMenu(false);
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setMenu(false);
        });
      }
    </script>

    <!-- Pageview beacon. Fires once per page load (MPA, no view transitions) and
         records a visit via the public analytics endpoint. Admin pages use a
         separate layout (AdminLayout), so backend traffic is excluded by design.
         Fire-and-forget: failures must never affect the page. -->
    <script>
      const apiUrl = document.body.dataset.apiUrl;
      if (apiUrl) {
        // Persistent anonymous browser id → real unique-visitor counts. Stored once
        // in localStorage and reused; never an IP, never PII. If storage/crypto is
        // blocked (private mode), fall through to an anonymous page view (no visitorId).
        let vid;
        try {
          vid = localStorage.getItem('wb_vid');
          if (!vid) {
            vid = (window.crypto && crypto.randomUUID)
              ? crypto.randomUUID()
              : 'v' + Date.now().toString(36) + Math.random().toString(36).slice(2, 10);
            localStorage.setItem('wb_vid', vid);
          }
        } catch (_) {
          vid = undefined;
        }
        fetch(`${apiUrl}/api/analytics/pageview`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            path: location.pathname,
            referrer: document.referrer || undefined,
            visitorId: vid || undefined,
          }),
          keepalive: true,
        }).catch(() => {});
      }
    </script>
  </body>
</html>

<style is:global>
  /* ── Reset ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  a { color: inherit; text-decoration: none; }

  /* ── Layout helpers ── */
  .wrap { max-width: var(--maxw); margin: 0 auto; padding-inline: var(--gut); }
  /* Page sections zero their own inline gut (.sec/.hero use `padding: V 0`)
     so the index spine bleeds to the band edge on wide screens. main supplies
     the gut so that below the band width (mobile + tablet) content keeps a
     readable gutter instead of touching the screen edge. On wide desktop the
     centering margin absorbs it (spine stays at the band edge). NOTE: a bare
     `.wrap` inside main would double-pad — sections must keep zeroing theirs. */
  main { padding-inline: var(--gut); }
  .row2 { display: grid; grid-template-columns: var(--spine) 1fr; gap: var(--col-gap); }
  .spine {
    position: sticky; top: 90px; align-self: start;
    display: flex; flex-direction: column; gap: 10px;
  }
  .spine .no {
    font-family: var(--font-display); font-weight: 300;
    font-size: clamp(34px, 4vw, 56px); line-height: .9;
    letter-spacing: -.03em; color: var(--ink-3);
  }
  .spine .lab {
    font-family: var(--font-mono); font-size: 12px;
    letter-spacing: .14em; text-transform: uppercase; color: var(--ink);
  }
  .spine .note {
    font-size: 13.5px; color: var(--ink-3); line-height: 1.5;
    max-width: 20ch; font-family: var(--font-read);
  }

  /* Row list language */
  .list { display: flex; flex-direction: column; }
  .item {
    display: grid; align-items: center;
    padding: 22px 4px; border-top: 1px solid var(--line);
    transition: padding-left .3s var(--ease), margin-right .3s var(--ease);
  }
  .item:first-child { border-top: none; padding-top: 2px; }
  /* Slide content right on hover via padding, compensated by an equal negative
     margin-right so the content width never changes (no line-break reflow) and
     the row's top hairline stays left-aligned (no jog). */
  .item:hover { padding-left: 14px; margin-right: -10px; }
  .item-title {
    font-family: var(--font-display); font-weight: 600;
    letter-spacing: -.018em; transition: color .2s;
  }
  .item:hover .item-title { color: var(--accent); }
  .item-sub { color: var(--ink-2); font-family: var(--font-read); }
  .item-meta {
    font-family: var(--font-mono); font-size: 11.5px;
    letter-spacing: .05em; color: var(--ink-3); white-space: nowrap;
  }

  /* ── Nav ── */
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--paper) 82%, transparent);
    backdrop-filter: saturate(150%) blur(16px);
    border-bottom: 1px solid transparent;
    transition: border-color .3s;
  }
  .nav.scrolled { border-bottom-color: var(--line); }
  .nav-in {
    display: flex; align-items: center;
    justify-content: space-between; height: 64px;
    position: relative; /* anchor for the mobile nav-links dropdown */
  }
  .brand {
    display: flex; align-items: center; gap: 8px;
    font-family: var(--font-display); font-weight: 600;
    font-size: 19px; letter-spacing: -.02em;
  }
  .brand .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); margin-top: 1px;
  }
  .nav-r { display: flex; align-items: center; gap: 4px; }
  .nav-r a {
    font-size: 14.5px; color: var(--ink-2);
    padding: 8px 13px; border-radius: 99px;
    transition: color .2s, background .2s;
  }
  .nav-r a:hover { color: var(--ink); background: var(--surface-2); }
  .nav-r a.active { color: var(--accent); font-weight: 500; }
  .icon-btn {
    width: 36px; height: 36px; display: grid; place-items: center;
    border: 1px solid var(--line); background: var(--surface);
    border-radius: 99px; cursor: pointer; color: var(--ink-2);
    transition: all .2s var(--ease); margin-left: 6px;
  }
  .icon-btn:hover { color: var(--ink); border-color: var(--line-2); }
  .icon-btn svg { width: 16px; height: 16px; }
  /* moon/sun toggle icons */
  .sun { display: none; }
  :root[data-theme="dark"] .sun { display: block; }
  :root[data-theme="dark"] .moon { display: none; }

  /* ── Nav links + mobile hamburger ── */
  .nav-links { display: flex; align-items: center; gap: 4px; }
  .nav-burger { display: none; }
  .nav-burger .burger-close { display: none; }
  .nav.menu-open .nav-burger .burger-open { display: none; }
  .nav.menu-open .nav-burger .burger-close { display: block; }
  /* Collapse the text nav into a hamburger dropdown on phones (the brand +
     theme + language controls stay on the bar). Below ~640px the inline links
     would overflow and clip the rightmost control. */
  @media (max-width: 640px) {
    .nav-burger { display: grid; }
    .nav-links {
      position: absolute; top: calc(100% + 8px); right: 0;
      flex-direction: column; align-items: stretch; gap: 2px;
      min-width: 168px; padding: 8px;
      background: var(--surface); border: 1px solid var(--line);
      border-radius: 16px; box-shadow: 0 14px 34px -14px rgba(0,0,0,.30);
      opacity: 0; visibility: hidden; transform: translateY(-6px);
      transition: opacity .18s var(--ease), transform .18s var(--ease), visibility .18s;
    }
    .nav.menu-open .nav-links { opacity: 1; visibility: visible; transform: translateY(0); }
    .nav-r a { width: 100%; padding: 10px 14px; border-radius: 10px; }
  }

  /* ── Language toggle (中 / EN) ──
     Mirrors the sun/moon pattern: default (zh) shows the alternative label
     (EN) as the click target; clicking switches data-lang and the active
     label highlights. Sized to fit the existing icon-btn footprint without
     changing its border/radius — the inner spans are text instead of SVG. */
  .lang-btn { font-family: var(--font-mono); font-size: 11.5px; letter-spacing: .04em; color: var(--ink-2); }
  .lang-btn:hover { color: var(--ink); }
  .lang-en { display: none; }
  :root[data-lang="en"] .lang-en { display: inline; color: var(--accent); font-weight: 600; }
  :root[data-lang="en"] .lang-zh { display: none; }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--line);
    padding: clamp(48px, 6vw, 76px) 0 36px;
  }
  .foot {
    display: grid;
    grid-template-columns: var(--spine) 1fr;
    gap: var(--col-gap);
  }
  .foot-l .brand { font-size: 22px; margin-bottom: 12px; }
  .foot-l p {
    color: var(--ink-2); font-size: 14.5px;
    line-height: 1.6; max-width: 30ch; font-family: var(--font-read);
  }
  .foot-cols { display: flex; gap: clamp(30px, 6vw, 90px); flex-wrap: wrap; }
  .foot-col h4 {
    font-family: var(--font-mono); font-size: 10.5px;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--ink-3); margin: 0 0 14px; font-weight: 500;
  }
  .foot-col a {
    display: block; color: var(--ink-2);
    font-size: 14.5px; padding: 5px 0; transition: color .2s;
  }
  .foot-col a:hover { color: var(--accent); }
  .foot-bot {
    grid-column: 1 / -1;
    display: flex; justify-content: space-between; gap: 16px;
    margin-top: 48px; padding-top: 24px;
    border-top: 1px solid var(--line); flex-wrap: wrap;
  }
  .foot-bot span {
    font-family: var(--font-mono); font-size: 11.5px;
    color: var(--ink-3); letter-spacing: .03em;
  }

  /* ── Responsive ── */
  @media (max-width: 880px) {
    .row2 { grid-template-columns: 1fr; gap: 22px; }
    .spine { position: static; flex-direction: row; align-items: baseline; gap: 14px; flex-wrap: wrap; }
    .spine .no { font-size: 30px; }
    .spine .note { display: none; }
    .foot { grid-template-columns: 1fr; gap: 30px; }
    .nav-r a:not(.keep) { /* keep all nav links visible on mobile */ }
  }
  @media (max-width: 560px) {
    .foot-bot { flex-direction: column; gap: 8px; }
