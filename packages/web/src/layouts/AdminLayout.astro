---
import '../styles/tokens.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: '📊' },
  { href: '/admin/observability', label: 'Observability', icon: '📈' },
  { href: '/admin/posts', label: 'Posts', icon: '📝' },
  { href: '/admin/media', label: 'Media', icon: '🖼' },
  { href: '/admin/categories', label: 'Categories', icon: '📁' },
  { href: '/admin/tags', label: 'Tags', icon: '🏷' },
  { href: '/admin/comments', label: 'Comments', icon: '💬' },
  { href: '/admin/settings', label: 'Settings', icon: '⚙' },
];
---

<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Wordbase Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <!-- FOUC-prevention bootstrap: read localStorage['norvyn-v2'] before paint.
         Mirrors BaseLayout's inline bootstrap so admin shares the same theme/accent
         preference as the public site. Keep in sync with src/lib/theme.ts. -->
    <script is:inline>
      (function() {
        var LS = 'norvyn-v2';
        var DEFAULT_THEME = 'light';
        var DEFAULT_ACCENT = '#3457B6';
        try {
          var stored = JSON.parse(localStorage.getItem(LS) || '{}');
          var theme = stored.theme || DEFAULT_THEME;
          var accent = stored.accent || DEFAULT_ACCENT;
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.setProperty('--accent', accent);
        } catch(e) {
          document.documentElement.setAttribute('data-theme', DEFAULT_THEME);
        }
      })();
    </script>
  </head>
  <body class="bg-paper min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-56 bg-surface-2 text-ink-2 flex flex-col border-r border-line">
        <div class="p-4 border-b border-line">
          <a href="/admin" class="text-lg font-bold text-ink">Wordbase</a>
          <p class="text-xs text-ink-3 mt-1">Admin Panel</p>
        </div>
        <nav class="flex-1 py-4">
          {navItems.map(item => {
            const isActive = currentPath === item.href ||
              (item.href !== '/admin' && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${
                  isActive
                    ? 'bg-surface-3 text-ink border-r-2 border-accent'
                    : 'hover:bg-surface-3 hover:text-ink'
                }`}
              >
                <span>{item.icon}</span>
                {item.label}
              </a>
            );
          })}
        </nav>
        <div class="p-4 border-t border-line flex items-center justify-between">
          <button
            id="logout-btn"
            class="text-sm text-ink-3 hover:text-ink transition-colors"
          >
            Logout
          </button>
          <button
            id="theme-btn"
            aria-label="Toggle theme"
            class="w-9 h-9 grid place-items-center rounded-full border border-line bg-surface text-ink-2 hover:text-ink hover:border-line-2 transition-colors"
          >
            <svg class="moon w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
            <svg class="sun w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.2"/><path d="M12 2.5v2.4M12 19.1v2.4M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.6 19.4l1.7-1.7M17.7 6.3l1.7-1.7"/></svg>
          </button>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col">
        <header class="bg-surface border-b border-line px-6 py-4">
          <h1 class="text-xl font-semibold text-ink">{title}</h1>
        </header>
        <main class="flex-1 p-6">
          <slot />
        </main>
      </div>
    </div>

    <style is:global>
      /* moon/sun toggle: show the icon for the theme you'd switch TO. */
      .sun { display: none; }
      :root[data-theme="dark"] .sun { display: block; }
      :root[data-theme="dark"] .moon { display: none; }
    </style>

    <script>
      // Auth check
      if (!localStorage.getItem('wordbase_api_key') && !window.location.pathname.includes('/login')) {
        window.location.href = '/admin/login';
      }

      document.getElementById('logout-btn')?.addEventListener('click', () => {
        localStorage.removeItem('wordbase_api_key');
        window.location.href = '/admin/login';
      });
    </script>

    <!-- Theme toggle. Reuses the tested persistence helpers in src/lib/theme.ts
         (single source of truth) and the shared 'norvyn-v2' key, so toggling here
         also themes the public site. Mirrors BaseLayout's toggle script. -->
    <script>
      import {
        THEME_LS_KEY,
        DEFAULT_THEME,
        readPrefs,
        mergePrefs,
        nextTheme,
        resolveAccent,
      } from '../lib/theme';

      function applyToDom(theme: string, accent: string) {
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.setProperty('--accent', accent);
      }

      const btn = document.getElementById('theme-btn');
      if (btn) {
        btn.addEventListener('click', () => {
          const prefs = readPrefs(localStorage.getItem(THEME_LS_KEY));
          const current = document.documentElement.getAttribute('data-theme') || DEFAULT_THEME;
          const theme = nextTheme(current);
          const accent = resolveAccent(prefs);
          localStorage.setItem(THEME_LS_KEY, JSON.stringify(mergePrefs(prefs, { theme, accent })));
          applyToDom(theme, accent);
        });
      }
    </script>
  </body>
</html>
