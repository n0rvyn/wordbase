---
interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin', label: 'Dashboard', icon: '📊' },
  { href: '/admin/observability', label: 'Observability', icon: '📈' },
  { href: '/admin/posts', label: 'Posts', icon: '📝' },
  { href: '/admin/media', label: 'Media', icon: '🖼' },
  { href: '/admin/categories', label: 'Categories', icon: '📁' },
  { href: '/admin/tags', label: 'Tags', icon: '🏷' },
  { href: '/admin/comments', label: 'Comments', icon: '💬' },
  { href: '/admin/settings', label: 'Settings', icon: '⚙' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Wordbase Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-gray-100 min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-56 bg-gray-900 text-gray-300 flex flex-col">
        <div class="p-4 border-b border-gray-700">
          <a href="/admin" class="text-lg font-bold text-white">Wordbase</a>
          <p class="text-xs text-gray-500 mt-1">Admin Panel</p>
        </div>
        <nav class="flex-1 py-4">
          {navItems.map(item => {
            const isActive = currentPath === item.href ||
              (item.href !== '/admin' && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${
                  isActive
                    ? 'bg-gray-800 text-white border-r-2 border-blue-500'
                    : 'hover:bg-gray-800 hover:text-white'
                }`}
              >
                <span>{item.icon}</span>
                {item.label}
              </a>
            );
          })}
        </nav>
        <div class="p-4 border-t border-gray-700">
          <button
            id="logout-btn"
            class="text-sm text-gray-400 hover:text-white transition-colors"
          >
            Logout
          </button>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col">
        <header class="bg-white border-b px-6 py-4">
          <h1 class="text-xl font-semibold text-gray-900">{title}</h1>
        </header>
        <main class="flex-1 p-6">
          <slot />
        </main>
      </div>
    </div>

    <script>
      // Auth check
      if (!localStorage.getItem('wordbase_api_key') && !window.location.pathname.includes('/login')) {
        window.location.href = '/admin/login';
      }

      document.getElementById('logout-btn')?.addEventListener('click', () => {
        localStorage.removeItem('wordbase_api_key');
        window.location.href = '/admin/login';
      });
    </script>
  </body>
</html>
